<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VhsMp4Optimizer.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="VhsMp4Optimizer.App.Views.AboutWindow"
        x:DataType="vm:AboutWindowViewModel"
        Width="760"
        Height="420"
        MinWidth="760"
        MinHeight="420"
        CanResize="False"
        Background="#F6F8FC"
        Title="About VHS MP4 Optimizer Next">

    <Border Margin="16"
            Padding="22"
            CornerRadius="18"
            Background="White"
            BorderBrush="#D8E0EF"
            BorderThickness="1">
        <Grid RowDefinitions="Auto,Auto,*"
              RowSpacing="18">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
                <StackPanel Spacing="6">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#152033"
                               Text="{Binding AppName}" />
                    <TextBlock Foreground="#55657D"
                               Text="Nova Avalonia baza za batch konverziju, trim i timeline rad." />
                </StackPanel>

                <Border Padding="12,8"
                        CornerRadius="12"
                        Background="#EEF5FF"
                        BorderBrush="#BFD4F4"
                        BorderThickness="1">
                    <StackPanel Spacing="2">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#4D6282"
                                   Text="VERSION" />
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#0F6D8A"
                                   Text="{Binding Version}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Padding="14"
                    CornerRadius="14"
                    Background="#F9FBFE"
                    BorderBrush="#E3EAF5"
                    BorderThickness="1">
                <Grid ColumnDefinitions="180,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="16"
                      RowSpacing="12">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="#152033"
                               Text="Release tag" />
                    <TextBlock Grid.Column="1"
                               Foreground="#2B3A4E"
                               Text="{Binding ReleaseTag}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="1"
                               FontWeight="SemiBold"
                               Foreground="#152033"
                               Text="Git ref" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Foreground="#2B3A4E"
                               Text="{Binding GitRef}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="2"
                               FontWeight="SemiBold"
                               Foreground="#152033"
                               Text="Install path" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Foreground="#2B3A4E"
                               Text="{Binding InstallPath}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="3"
                               FontWeight="SemiBold"
                               Foreground="#152033"
                               Text="User guide" />
                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               Foreground="#2B3A4E"
                               Text="{Binding GuidePath}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="4"
                               FontWeight="SemiBold"
                               Foreground="#152033"
                               Text="Migration branch" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Foreground="#2B3A4E"
                               Text="{Binding BranchHint}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="14"
                    CornerRadius="14"
                    Background="#F4F8FC"
                    BorderBrush="#E3EAF5"
                    BorderThickness="1">
                <TextBlock Foreground="#4A5C75"
                           TextWrapping="Wrap"
                           Text="Verzija je prikazana u jasnom a.b.c formatu kao na GitHub release-u. Release tag pokazuje tačnu javnu oznaku paketa, a Git ref govori iz kog je commita aplikacija sastavljena." />
            </Border>
        </Grid>
    </Border>
</Window>
