<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VhsMp4Optimizer.App.ViewModels"
        xmlns:core="using:VhsMp4Optimizer.Core.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1500"
        d:DesignHeight="940"
        x:Name="RootWindow"
        x:Class="VhsMp4Optimizer.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        Background="#F3F6FB"
        Foreground="#17212F"
        MinWidth="1260"
        MinHeight="820">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D6DEEA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style Selector="Border.subtle-group">
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="BorderBrush" Value="#E1E7F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F1728" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style Selector="TextBlock.group-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#243247" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#445166" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style Selector="TextBlock.hint">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#66758C" />
        </Style>

        <Style Selector="GridSplitter.h-splitter">
            <Setter Property="Background" Value="#CCD7E6" />
            <Setter Property="Height" Value="10" />
        </Style>

        <Style Selector="GridSplitter.v-splitter">
            <Setter Property="Background" Value="#CCD7E6" />
            <Setter Property="Width" Value="10" />
        </Style>

        <Style Selector="Button.action">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="Button.primary-big">
            <Setter Property="MinHeight" Value="70" />
            <Setter Property="MinWidth" Value="230" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#138AA6" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <Grid x:Name="MainLayoutGrid"
          RowDefinitions="Auto,112,10,164,10,176,10,*,10,220"
          Margin="16"
          DragDrop.AllowDrop="True">
        <Menu Grid.Row="0" Margin="0,0,0,10">
            <MenuItem Header="_File">
                <MenuItem Header="Scan Files" Command="{Binding ScanFilesCommand}" />
                <MenuItem Header="Open Output" Command="{Binding OpenOutputCommand}" />
                <Separator />
                <MenuItem Header="Save Queue" Click="SaveQueueClick" />
                <MenuItem Header="Load Queue" Click="LoadQueueClick" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Save Layout" Click="SaveLayoutClick" />
                <MenuItem Header="Restore Default Layout" Click="RestoreDefaultLayoutClick" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Browse FFmpeg..." Click="BrowseFfmpegClick" />
                <MenuItem Header="Auto detect FFmpeg" Click="AutoDetectFfmpegClick" />
                <MenuItem Header="Install FFmpeg" Click="InstallFfmpegClick" />
                <Separator />
                <MenuItem Header="Open Player / Trim" Click="OpenPlayerTrimClick" />
                <MenuItem Header="Test Sample" Command="{Binding TestSampleCommand}" />
                <MenuItem Header="Open Sample" Command="{Binding OpenSampleCommand}" />
                <Separator />
                <MenuItem Header="Split Selected (Copy)" Command="{Binding SplitSelectedCopyCommand}" />
                <MenuItem Header="Join Files (Copy)" Click="JoinFilesCopyClick" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Check for Updates" Click="CheckForUpdatesClick" />
                <MenuItem Header="Open User Guide" Click="OpenUserGuideClick" />
                <Separator />
                <MenuItem Header="About" Click="OpenAboutClick" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Classes="card">
            <Grid ColumnDefinitions="*,16,*">
                <Border Grid.Column="0" Background="#F8FAFD" BorderBrush="#E1E7F0" BorderThickness="1" CornerRadius="10" Padding="12">
                    <Grid ColumnDefinitions="90,*,92,92" ColumnSpacing="10">
                        <TextBlock Classes="section-title" Grid.ColumnSpan="4" Text="Input folder" />
                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Source" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding InputFolder}" PlaceholderText="Izaberi ulazni folder ili fajlove" />
                        <Button Grid.Row="1" Grid.Column="2" Classes="action" Content="Files..." Click="BrowseInputFilesClick" />
                        <Button Grid.Row="1" Grid.Column="3" Classes="action" Content="Folder..." Click="BrowseInputFolderClick" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Classes="hint" Text="{Binding SelectionHint}" TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="#F8FAFD" BorderBrush="#E1E7F0" BorderThickness="1" CornerRadius="10" Padding="12">
                    <Grid ColumnDefinitions="90,*,112" ColumnSpacing="10">
                        <TextBlock Classes="section-title" Grid.ColumnSpan="3" Text="Output folder" />
                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Target" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OutputFolder}" PlaceholderText="Podrazumevani izlazni folder" />
                        <Button Grid.Row="1" Grid.Column="2" Classes="action" Content="Browse..." Click="BrowseOutputFolderClick" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="2" Classes="h-splitter" HorizontalAlignment="Stretch" ResizeDirection="Rows" />

        <Border Grid.Row="3" Classes="card">
            <Grid ColumnDefinitions="*,20,430" ColumnSpacing="0">
                <Grid Grid.Column="0" ColumnDefinitions="210,180,150,150,150" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="section-title" Text="Quick Setup" />
                        <TextBlock Classes="field-label" Text="Workflow preset" />
                        <ComboBox ItemsSource="{Binding WorkflowPresets}" SelectedItem="{Binding SelectedPreset}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,26,0,0" Spacing="4">
                        <TextBlock Classes="field-label" Text="Quality mode" />
                        <ComboBox ItemsSource="{Binding QualityModes}" SelectedItem="{Binding QualityMode}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,26,0,0" Spacing="4">
                        <TextBlock Classes="field-label" Text="Scale" />
                        <ComboBox ItemsSource="{Binding ScaleModes}" SelectedItem="{Binding ScaleMode}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,26,0,0" Spacing="4">
                        <TextBlock Classes="field-label" Text="Video bitrate" />
                        <TextBox Text="{Binding VideoBitrate}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="0,26,0,0" Spacing="4">
                        <TextBlock Classes="field-label" Text="Audio bitrate" />
                        <TextBox Text="{Binding AudioBitrate}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Column="2" Classes="subtle-group">
                    <Grid ColumnDefinitions="1.2*,1.5*" RowDefinitions="Auto,*" ColumnSpacing="12">
                        <TextBlock Classes="group-title" Text="Batch actions" />
                        <TextBlock Grid.Column="1" Classes="group-title" Text="Render" />

                        <Grid Grid.Row="1" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                            <Button Grid.Column="0" Classes="action" Content="Scan Files" Command="{Binding ScanFilesCommand}" />
                            <Button Grid.Column="1" Classes="action" Content="Open Player / Trim" Click="OpenPlayerTrimClick" />
                            <Button Grid.Row="1" Grid.Column="0" Classes="action" Content="Open Output" Command="{Binding OpenOutputCommand}" />
                            <Button Grid.Row="1" Grid.Column="1" Classes="action" Content="Save Queue" Click="SaveQueueClick" />
                            <Button Grid.Row="2" Grid.Column="0" Classes="action" Content="Load Queue" Click="LoadQueueClick" />
                            <Button Grid.Row="2" Grid.Column="1" Classes="action" Content="{Binding PauseResumeLabel}" Command="{Binding PauseResumeCommand}" />
                        </Grid>

                        <Border Grid.Row="1" Grid.Column="1" Background="#F4FAFC" BorderBrush="#B8DDE5" BorderThickness="1" CornerRadius="10" Padding="12">
                            <StackPanel VerticalAlignment="Center" Spacing="12">
                                <Button Classes="primary-big" Content="POKRENI KONVERZIJU" Command="{Binding StartConversionCommand}" />
                                <TextBlock Classes="hint"
                                           Text="Batch konverzija, test sample i trim koriste ista izlazna podesavanja."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="4" Classes="h-splitter" HorizontalAlignment="Stretch" ResizeDirection="Rows" />

        <Border Grid.Row="5" Classes="card">
            <StackPanel Spacing="10">
                <TextBlock Classes="section-title" Text="Advanced Settings" />
                <WrapPanel Orientation="Horizontal" ItemWidth="210" ItemHeight="124">
                    <Border Classes="subtle-group" Margin="0,0,10,10">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="field-label" Text="Deinterlace" />
                            <ComboBox ItemsSource="{Binding DeinterlaceModes}" SelectedItem="{Binding DeinterlaceMode}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="subtle-group" Margin="0,0,10,10">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="field-label" Text="Denoise" />
                            <ComboBox ItemsSource="{Binding DenoiseModes}" SelectedItem="{Binding DenoiseMode}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="subtle-group" Margin="0,0,10,10">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="field-label" Text="Aspect mode" />
                            <ComboBox ItemsSource="{Binding AspectModes}" SelectedItem="{Binding AspectMode}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="subtle-group" Margin="0,0,10,10">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="field-label" Text="Encode engine" />
                            <ComboBox ItemsSource="{Binding EncodeEngines}" SelectedItem="{Binding EncodeEngine}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="subtle-group" Margin="0,0,10,10">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="field-label" Text="Split output" />
                            <CheckBox Content="Enable split" IsChecked="{Binding SplitOutput}" />
                            <TextBlock Classes="field-label" Text="Max part GB" />
                            <NumericUpDown Value="{Binding MaxPartGb}" Minimum="0.5" Maximum="25" Increment="0.1" FormatString="0.0" />
                        </StackPanel>
                    </Border>

                    <Border Classes="subtle-group" Margin="0,0,10,10">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="field-label" Text="Sample clip" />
                            <TextBox Text="{Binding SampleStartText}" PlaceholderText="Sample start (00:00:30)" />
                            <TextBox Text="{Binding SampleDurationText}" PlaceholderText="Sample duration (00:02:00)" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Grid.Column="0" Classes="action" Content="Test Sample" Command="{Binding TestSampleCommand}" />
                                <Button Grid.Column="1" Classes="action" Content="Open Sample" Command="{Binding OpenSampleCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Border>

        <GridSplitter Grid.Row="6" Classes="h-splitter" HorizontalAlignment="Stretch" ResizeDirection="Rows" />

        <Grid x:Name="WorkspaceGrid" Grid.Row="7" ColumnDefinitions="3*,10,2*">
            <Border Grid.Column="0" Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                    <TextBlock Classes="section-title" Text="Queue" />

                    <WrapPanel Grid.Row="1" ItemHeight="38" Margin="0,0,0,4">
                        <Button Margin="0,0,8,8" Classes="action" Content="Skip Selected" Command="{Binding SkipSelectedCommand}" />
                        <Button Margin="0,0,8,8" Classes="action" Content="Split Selected (Copy)" Command="{Binding SplitSelectedCopyCommand}" />
                        <Button Margin="0,0,8,8" Classes="action" Content="Join Files (Copy)" Click="JoinFilesCopyClick" />
                        <Button Margin="0,0,8,8" Classes="action" Content="Retry Failed" Command="{Binding RetryFailedCommand}" />
                        <Button Margin="0,0,8,8" Classes="action" Content="Clear Completed" Command="{Binding ClearCompletedCommand}" />
                    </WrapPanel>

                    <Border Grid.Row="2" Background="#F5F7FB" BorderBrush="#E4EAF2" BorderThickness="1" CornerRadius="8" Padding="8">
                        <Grid ColumnDefinitions="2.3*,2.3*,1.1*,1.1*,1.1*,1.6*,1.4*,1.1*" ColumnSpacing="8">
                            <TextBlock Text="Source file" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Output file" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Container" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Resolution" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Duration" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="Video" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="Audio" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="7" Text="Status" FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="3"
                             ItemsSource="{Binding QueueItems}"
                             SelectedItem="{Binding SelectedQueueItem}"
                             Background="Transparent"
                             BorderThickness="0"
                             DoubleTapped="QueueListDoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="core:QueueItemSummary">
                                <Border Padding="8"
                                        Margin="0,0,0,6"
                                        Background="{Binding RowBackground}"
                                        BorderBrush="#E4EAF2"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid ColumnDefinitions="2.3*,2.3*,1.1*,1.1*,1.1*,1.6*,1.4*,1.1*" ColumnSpacing="8">
                                        <TextBlock Text="{Binding SourceFile}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding OutputFile}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding Container}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Resolution}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Duration}" />
                                        <TextBlock Grid.Column="5" Text="{Binding Video}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="6" Text="{Binding Audio}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="7" Text="{Binding Status}" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Classes="v-splitter" VerticalAlignment="Stretch" ResizeDirection="Columns"/>

            <Border Grid.Column="2" Classes="card">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                    <TextBlock Classes="section-title" Text="Input / Planned output" />

                    <Border Grid.Row="1" Background="#F5F7FB" BorderBrush="#E4EAF2" BorderThickness="1" CornerRadius="8" Padding="8">
                        <Grid ColumnDefinitions="1.1*,1.7*,1.7*" ColumnSpacing="10">
                            <TextBlock Text="Parametar" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Input" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Planned output" FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding ComparisonRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="core:PropertyComparisonRow">
                                    <Border Margin="0,0,0,6"
                                            Padding="8"
                                            Background="{Binding RowBackground}"
                                            BorderBrush="#E4EAF2"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid ColumnDefinitions="1.1*,1.7*,1.7*" ColumnSpacing="10">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding InputValue}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="2" Text="{Binding OutputValue}" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="8" Classes="h-splitter" HorizontalAlignment="Stretch" ResizeDirection="Rows"/>

        <Border Grid.Row="9" Classes="card">
            <TabControl>
                <TabItem Header="Status">
                    <Border Padding="12">
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    </Border>
                </TabItem>
                <TabItem Header="Progress">
                    <Border Padding="12">
                        <TextBlock Text="{Binding ProgressMessage}" TextWrapping="Wrap" />
                    </Border>
                </TabItem>
                <TabItem Header="Log">
                    <Border Padding="12">
                        <TextBlock Text="{Binding LogMessage}" TextWrapping="Wrap" />
                    </Border>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
