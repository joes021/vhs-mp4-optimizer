<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VhsMp4Optimizer.App.ViewModels"
        xmlns:core="using:VhsMp4Optimizer.Core.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="900"
        x:Class="VhsMp4Optimizer.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        Background="#F3F6FB"
        Foreground="#17212F"
        MinWidth="1200"
        MinHeight="780">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D6DEEA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style Selector="GridSplitter.h-splitter">
            <Setter Property="Background" Value="#D6DEEA" />
            <Setter Property="Height" Value="10" />
        </Style>

        <Style Selector="GridSplitter.v-splitter">
            <Setter Property="Background" Value="#D6DEEA" />
            <Setter Property="Width" Value="10" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F1728" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#445166" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style Selector="TextBlock.hint">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#66758C" />
        </Style>

        <Style Selector="Button.quick-action">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,10,*,10,220" Margin="16">
        <Grid Grid.Row="0" ColumnDefinitions="*,16,*" Margin="0,0,0,10">
            <Border Grid.Column="0" Classes="card">
                <Grid ColumnDefinitions="90,*,90,90" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Classes="section-title" Grid.Row="0" Grid.ColumnSpan="4" Text="Input folder" />
                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Source" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding InputFolder}" PlaceholderText="Izaberi ulazni folder ili fajlove" />
                    <Button Grid.Row="1" Grid.Column="2" Content="Files..." HorizontalAlignment="Stretch" Click="BrowseInputFilesClick" />
                    <Button Grid.Row="1" Grid.Column="3" Content="Folder..." HorizontalAlignment="Stretch" Click="BrowseInputFolderClick" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Grid.ColumnSpan="3"
                               Classes="hint"
                               Text="{Binding SelectionHint}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Classes="card">
                <Grid ColumnDefinitions="90,*,110" ColumnSpacing="10" RowDefinitions="Auto,Auto">
                    <TextBlock Classes="section-title" Grid.Row="0" Grid.ColumnSpan="3" Text="Output folder" />
                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Target" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OutputFolder}" PlaceholderText="Podrazumevani izlazni folder" />
                    <Button Grid.Row="1" Grid.Column="2" Content="Browse..." HorizontalAlignment="Stretch" Click="BrowseOutputFolderClick" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" Classes="card" Margin="0,0,0,10">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                <TextBlock Classes="section-title" Text="Quick Setup" />

                <Grid Grid.Row="1" ColumnDefinitions="220,190,150,150,150,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0">
                        <TextBlock Classes="field-label" Text="Workflow preset" />
                        <ComboBox ItemsSource="{Binding WorkflowPresets}" SelectedItem="{Binding SelectedPreset}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Classes="field-label" Text="Quality mode" />
                        <ComboBox ItemsSource="{Binding QualityModes}" SelectedItem="{Binding QualityMode}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Classes="field-label" Text="Scale" />
                        <ComboBox ItemsSource="{Binding ScaleModes}" SelectedItem="{Binding ScaleMode}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Classes="field-label" Text="Video bitrate" />
                        <TextBox Text="{Binding VideoBitrate}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Classes="field-label" Text="Audio bitrate" />
                        <TextBox Text="{Binding AudioBitrate}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="8">
                    <Button Grid.Row="0" Grid.Column="0" Classes="quick-action" Content="Scan Files" Command="{Binding ScanFilesCommand}" />
                    <Button Grid.Row="0" Grid.Column="1" Classes="quick-action" Content="Open Player / Trim" Click="OpenPlayerTrimClick" />
                    <Button Grid.Row="0" Grid.Column="2" Classes="quick-action" Content="Open Output" Command="{Binding OpenOutputCommand}" />
                    <Button Grid.Row="0" Grid.Column="3" Classes="quick-action accent" Content="Start Conversion" Command="{Binding StartConversionCommand}" />
                    <Button Grid.Row="0" Grid.Column="4" Classes="quick-action" Content="{Binding PauseResumeLabel}" Command="{Binding PauseResumeCommand}" />
                    <Button Grid.Row="0" Grid.Column="5" Classes="quick-action" Content="About" Click="OpenAboutClick" />

                    <Button Grid.Row="1" Grid.Column="0" Classes="quick-action" Content="Test Sample" Command="{Binding TestSampleCommand}" />
                    <Button Grid.Row="1" Grid.Column="1" Classes="quick-action" Content="Open Sample" Command="{Binding OpenSampleCommand}" />
                    <Button Grid.Row="1" Grid.Column="2" Classes="quick-action" Content="Save Queue" Click="SaveQueueClick" />
                    <Button Grid.Row="1" Grid.Column="3" Classes="quick-action" Content="Load Queue" Click="LoadQueueClick" />
                    <Button Grid.Row="1" Grid.Column="4" Classes="quick-action" Content="Open User Guide" Click="OpenUserGuideClick" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Classes="card">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                <TextBlock Classes="section-title" Text="Advanced Settings" />
                <Grid Grid.Row="1" ColumnDefinitions="150,150,180,170,180,170,170" ColumnSpacing="12">
                    <StackPanel Grid.Column="0">
                        <TextBlock Classes="field-label" Text="Deinterlace" />
                        <ComboBox SelectedIndex="0">
                            <ComboBoxItem Content="Off" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Classes="field-label" Text="Denoise" />
                        <ComboBox SelectedIndex="0">
                            <ComboBoxItem Content="Off" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Classes="field-label" Text="Aspect mode" />
                        <ComboBox ItemsSource="{Binding AspectModes}" SelectedItem="{Binding AspectMode}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Classes="field-label" Text="Encode engine" />
                        <ComboBox SelectedIndex="0">
                            <ComboBoxItem Content="Auto" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Spacing="6">
                        <TextBlock Classes="field-label" Text="Split output" />
                        <CheckBox Content="Enable split" IsChecked="{Binding SplitOutput}" />
                        <TextBlock Classes="field-label" Text="Max part GB" Margin="0,4,0,4" />
                        <NumericUpDown Value="{Binding MaxPartGb}" Minimum="0.5" Maximum="25" Increment="0.1" FormatString="0.0" />
                    </StackPanel>

                    <StackPanel Grid.Column="5">
                        <TextBlock Classes="field-label" Text="Sample start" />
                        <TextBox Text="{Binding SampleStartText}" PlaceholderText="00:00:30" />
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Classes="field-label" Text="Sample duration" />
                        <TextBox Text="{Binding SampleDurationText}" PlaceholderText="00:02:00" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="3" Classes="h-splitter" HorizontalAlignment="Stretch" ResizeDirection="Rows" />

        <Grid Grid.Row="4" ColumnDefinitions="1.4*,10,*">
            <Border Grid.Column="0" Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                    <TextBlock Classes="section-title" Text="Queue" />

                    <WrapPanel Grid.Row="1">
                        <Button Margin="0,0,8,8" Content="Skip Selected" Command="{Binding SkipSelectedCommand}" />
                        <Button Margin="0,0,8,8" Content="Split Selected (Copy)" Command="{Binding SplitSelectedCopyCommand}" />
                        <Button Margin="0,0,8,8" Content="Join Files (Copy)" Click="JoinFilesCopyClick" />
                        <Button Margin="0,0,8,8" Content="Retry Failed" Command="{Binding RetryFailedCommand}" />
                        <Button Margin="0,0,8,8" Content="Clear Completed" Command="{Binding ClearCompletedCommand}" />
                    </WrapPanel>

                    <Border Grid.Row="2" Background="#F5F7FB" BorderBrush="#E4EAF2" BorderThickness="1" CornerRadius="8" Padding="8">
                        <Grid ColumnDefinitions="2.3*,2.3*,1.1*,1.1*,1.1*,1.6*,1.4*,1.1*" ColumnSpacing="8">
                            <TextBlock Text="Source file" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Output file" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Container" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Resolution" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Duration" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="Video" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="Audio" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="7" Text="Status" FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="3"
                             ItemsSource="{Binding QueueItems}"
                             SelectedItem="{Binding SelectedQueueItem}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="core:QueueItemSummary">
                                <Border Padding="8"
                                        Margin="0,0,0,6"
                                        Background="#FBFCFE"
                                        BorderBrush="#E4EAF2"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid ColumnDefinitions="2.3*,2.3*,1.1*,1.1*,1.1*,1.6*,1.4*,1.1*" ColumnSpacing="8">
                                        <TextBlock Text="{Binding SourceFile}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding OutputFile}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding Container}" />
                                        <TextBlock Grid.Column="3" Text="{Binding Resolution}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Duration}" />
                                        <TextBlock Grid.Column="5" Text="{Binding Video}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="6" Text="{Binding Audio}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="7" Text="{Binding Status}" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Classes="v-splitter" VerticalAlignment="Stretch" ResizeDirection="Columns" />

            <Border Grid.Column="2" Classes="card">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                    <TextBlock Classes="section-title" Text="Input / Planned output" />

                    <Border Grid.Row="1" Background="#F5F7FB" BorderBrush="#E4EAF2" BorderThickness="1" CornerRadius="8" Padding="8">
                        <Grid ColumnDefinitions="1.1*,1.7*,1.7*" ColumnSpacing="10">
                            <TextBlock Text="Parametar" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Input" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Planned output" FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding ComparisonRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="core:PropertyComparisonRow">
                                    <Border Margin="0,0,0,6"
                                            Padding="8"
                                            Background="#FBFCFE"
                                            BorderBrush="#E4EAF2"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid ColumnDefinitions="1.1*,1.7*,1.7*" ColumnSpacing="10">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding InputValue}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="2" Text="{Binding OutputValue}" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="5" Classes="h-splitter" HorizontalAlignment="Stretch" ResizeDirection="Rows" />

        <Border Grid.Row="6" Classes="card">
            <TabControl>
                <TabItem Header="Status">
                    <Border Padding="12">
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    </Border>
                </TabItem>
                <TabItem Header="Progress">
                    <Border Padding="12">
                        <TextBlock Text="{Binding ProgressMessage}" TextWrapping="Wrap" />
                    </Border>
                </TabItem>
                <TabItem Header="Log">
                    <Border Padding="12">
                        <TextBlock Text="{Binding LogMessage}" TextWrapping="Wrap" />
                    </Border>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
