<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VhsMp4Optimizer.App.ViewModels"
        xmlns:core="using:VhsMp4Optimizer.Core.Models"
        xmlns:controls="using:VhsMp4Optimizer.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="RootWindow"
        x:Class="VhsMp4Optimizer.App.Views.PlayerTrimWindow"
        x:DataType="vm:PlayerTrimWindowViewModel"
        Width="1560"
        Height="1020"
        MinWidth="1200"
        MinHeight="820"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        Background="#14181F"
        Foreground="#E6EDF7">

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#1B222C" />
            <Setter Property="BorderBrush" Value="#2C3745" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style Selector="Border.panel-muted">
            <Setter Property="Background" Value="#111821" />
            <Setter Property="BorderBrush" Value="#2A3340" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F2F5F9" />
        </Style>

        <Style Selector="TextBlock.section-meta">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#96A4B8" />
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8FA2BA" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style Selector="Button.transport">
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Background" Value="#283240" />
            <Setter Property="Foreground" Value="#EEF4FB" />
            <Setter Property="BorderBrush" Value="#314055" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.transport:pointerover">
            <Setter Property="Background" Value="#184D30" />
            <Setter Property="BorderBrush" Value="#6FC993" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport:pressed">
            <Setter Property="Background" Value="#133F27" />
            <Setter Property="BorderBrush" Value="#A4E3BE" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport:disabled">
            <Setter Property="Background" Value="#37485D" />
            <Setter Property="BorderBrush" Value="#607790" />
            <Setter Property="Foreground" Value="#D5E2F3" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.transport.active-chip">
            <Setter Property="Background" Value="#405876" />
            <Setter Property="BorderBrush" Value="#A6BCD3" />
            <Setter Property="Foreground" Value="#F5FAFF" />
        </Style>

        <Style Selector="Button.transport.functional">
            <Setter Property="Background" Value="#1E6A39" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#8BE0A6" />
        </Style>

        <Style Selector="Button.transport.functional:pointerover">
            <Setter Property="Background" Value="#184D30" />
            <Setter Property="BorderBrush" Value="#B0ECC7" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport.functional:pressed">
            <Setter Property="Background" Value="#133F27" />
            <Setter Property="BorderBrush" Value="#D0F7DE" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport.functional.active-chip">
            <Setter Property="Background" Value="#1F7A43" />
            <Setter Property="BorderBrush" Value="#C8F5D7" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport.functional:disabled">
            <Setter Property="Background" Value="#244B35" />
            <Setter Property="BorderBrush" Value="#4F8A68" />
            <Setter Property="Foreground" Value="#D7F5E0" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.transport:disabled /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="#D5E2F3" />
        </Style>

        <Style Selector="Button.transport.functional:disabled /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="#D7F5E0" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0E7490" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBox, ComboBox, NumericUpDown">
            <Setter Property="Background" Value="#0E151D" />
            <Setter Property="Foreground" Value="#EEF4FB" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="14" RowSpacing="14">
        <StackPanel Grid.Row="0" Spacing="10">
            <Border x:Name="MockupMenuBar" Classes="panel-muted" Padding="10,8">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <TextBlock Classes="field-label"
                               VerticalAlignment="Center"
                               Text="FILE MENU" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <Button Classes="transport" Content="File" />
                        <Button Classes="transport" Content="Edit" />
                        <Button Classes="transport" Content="Trim" />
                        <Button Classes="transport" Content="Timeline" />
                        <Button Classes="transport" Content="Clip" />
                        <Button Classes="transport" Content="Mark" />
                        <Button Classes="transport" Content="View" />
                        <Button Classes="transport" Content="Playback" />
                        <Button Classes="transport" Content="Workspace" />
                        <Button Classes="transport" Content="Help" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="LegacyTrimChrome" Classes="panel-muted" Padding="12,10" IsVisible="False" />
        </StackPanel>

        <Grid x:Name="EditorMockupGrid"
              Grid.Row="1"
              ColumnDefinitions="250,*,320"
              RowDefinitions="Auto,Auto,*"
              ColumnSpacing="14"
              RowSpacing="14">
            <Border x:Name="MockupMediaFilesPanel"
                    Grid.Row="0"
                    Grid.Column="0"
                    Classes="panel">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-title" Text="MEDIA FILES" />
                    <TextBlock Classes="section-meta" Text="Izvorni video klipovi za timeline" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsMediaPoolActive}"
                                Content="Clips"
                                Command="{Binding SelectWorkspaceDockCommand}"
                                CommandParameter="Media Pool" />
                        <Button Classes="transport" Content="Timelines" />
                    </StackPanel>

                    <Border Classes="panel-muted">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="field-label" Text="Aktivan klip" />
                            <Border Height="88"
                                    Background="#253243"
                                    BorderBrush="#405468"
                                    BorderThickness="1"
                                    CornerRadius="8" />
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding Item.SourceFile}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Classes="section-meta" Text="Source Clip" />
                        </StackPanel>
                    </Border>

                    <Border Classes="panel-muted">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="field-label" Text="Info" />
                            <TextBlock Text="{Binding FileSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border x:Name="MockupPreviewPanel"
                    Grid.Row="0"
                    Grid.Column="1"
                    Classes="panel">
                <Grid x:Name="CenterMonitorGrid"
                      RowDefinitions="Auto,360,Auto,Auto"
                      RowSpacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <TextBlock Classes="section-title"
                                   VerticalAlignment="Center"
                                   Text="VIDEO" />
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="{Binding FileSummary}"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="2"
                                Classes="transport functional"
                                Content="Back to Queue"
                                Click="ClosePlayerTrimClick" />
                    </Grid>

                    <Border x:Name="PrimaryProgramMonitor"
                            Grid.Row="1"
                            Height="360"
                            Background="#05080D"
                            BorderBrush="#2C3745"
                            BorderThickness="1"
                            CornerRadius="10"
                            ClipToBounds="True">
                        <Border x:Name="ProgramMonitorViewport"
                                Margin="8"
                                Background="#05080D"
                                BorderBrush="#293445"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <Grid>
                                <controls:EmbeddedVideoView x:Name="PlaybackVideoView"
                                                            MediaPlayer="{Binding PlaybackMediaPlayerBinding}"
                                                            IsVisible="{Binding IsVideoPlaybackVisible}"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch" />
                                <Image Source="{Binding PreviewBitmap}"
                                       IsVisible="{Binding IsPreviewImageVisible}"
                                       IsHitTestVisible="False"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Stretch="Uniform" />
                            </Grid>
                        </Border>
                    </Border>

                    <Border x:Name="PreviewScrubBar"
                            Grid.Row="2"
                            Classes="panel-muted"
                            Padding="8,4">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{Binding PreviewVirtualTimeText}" />
                            <Slider Grid.Column="1"
                                    Minimum="0"
                                    Maximum="{Binding PreviewVirtualMaximum}"
                                    Value="{Binding PreviewVirtualSeconds, Mode=TwoWay}"
                                    PointerPressed="PreviewSliderPointerPressed"
                                    PointerReleased="PreviewSliderPointerReleased" />
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{Binding PreviewDurationText}" />
                        </Grid>
                    </Border>

                    <Border x:Name="MonitorTransportBand"
                            Grid.Row="3"
                            Classes="panel-muted"
                            Padding="8,6">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="transport functional" Content="START" Command="{Binding GoToStartCommand}" />
                                    <Button Classes="transport functional" Content="&lt;&lt;&lt;" Command="{Binding Back250FramesCommand}" />
                                    <Button Classes="transport functional" Content="&lt;&lt;" Command="{Binding Back25FramesCommand}" />
                                    <Button Classes="transport functional" Content="&lt;" Command="{Binding BackFrameCommand}" />
                                    <Button Classes="transport functional" Content="&gt;" Command="{Binding ForwardFrameCommand}" />
                                    <Button Classes="transport functional" Content="&gt;&gt;" Command="{Binding Forward25FramesCommand}" />
                                    <Button Classes="transport functional" Content="&gt;&gt;&gt;" Command="{Binding Forward250FramesCommand}" />
                                    <Button Classes="transport functional" Content="END" Command="{Binding GoToEndCommand}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="transport functional" Content="Play" Command="{Binding PlayCommand}" />
                                    <Button Classes="transport functional" Content="Pause" Command="{Binding PauseCommand}" />
                                    <Button Classes="transport functional"
                                            Classes.active-chip="{Binding IsLoopPlaybackEnabled}"
                                            Content="Loop"
                                            Command="{Binding ToggleLoopPlaybackCommand}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="transport functional" Content="Mark In" Command="{Binding SetInPointCommand}" />
                                    <Button Classes="transport functional" Content="Mark Out" Command="{Binding SetOutPointCommand}" />
                                    <Button Classes="transport functional" Content="Prev Cut" Command="{Binding PreviousCutCommand}" />
                                    <Button Classes="transport functional" Content="Next Cut" Command="{Binding NextCutCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="MockupClipToolsPanel"
                    Grid.Row="0"
                    Grid.Column="2"
                    Classes="panel">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="section-title" Text="TOOLS ZA POJEDINACNE VIDEO KLIPOVE" />
                        <TextBlock Classes="section-meta" Text="Croping, stabilizacija, brzina i ostale pojedinacne izmene" />

                        <Button Classes="transport functional"
                                Content="Save to Queue"
                                Command="{Binding SaveToQueueCommand}" />

                        <Border Classes="panel-muted">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="field-label" Text="Aspect" />
                                <ComboBox ItemsSource="{Binding AspectModes}"
                                          SelectedItem="{Binding SelectedAspectMode}" />
                            </StackPanel>
                        </Border>

                        <Border Classes="panel-muted">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="field-label" Text="Cropping" />
                                <Grid ColumnDefinitions="Auto,70,Auto,70"
                                      ColumnSpacing="8"
                                      RowDefinitions="Auto,Auto">
                                    <TextBlock VerticalAlignment="Center" Text="L" />
                                    <NumericUpDown Grid.Column="1" Value="{Binding CropLeft}" Minimum="0" Maximum="2000" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="T" />
                                    <NumericUpDown Grid.Column="3" Value="{Binding CropTop}" Minimum="0" Maximum="2000" />
                                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="R" />
                                    <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding CropRight}" Minimum="0" Maximum="2000" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="B" />
                                    <NumericUpDown Grid.Row="1" Grid.Column="3" Value="{Binding CropBottom}" Minimum="0" Maximum="2000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                    <Button Grid.Column="0" Classes="transport functional" Content="Detect Crop" Command="{Binding DetectCropCommand}" />
                                    <Button Grid.Column="1" Classes="transport functional" Content="Auto Crop" Command="{Binding AutoCropCommand}" />
                                    <Button Grid.Column="2" Classes="transport functional" Content="Clear Crop" Command="{Binding ClearCropCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="panel-muted">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="field-label" Text="Selected Clip" />
                                <TextBlock Text="{Binding TimelineSummary}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedClipSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Classes="panel-muted">
                            <TextBlock Classes="section-meta"
                                       Text="{Binding EditorHint}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="TrackToolsBar"
                    Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Classes="panel-muted"
                    Padding="10,8">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="section-title"
                                   VerticalAlignment="Center"
                                   Text="TOOLS ZA VIDEO TRACKS" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsSelectToolActive}"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Select"
                                Content="Select" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsBladeToolActive}"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Blade"
                                Content="Razor" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsSlipToolActive}"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Slip"
                                Content="Slip" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsRollToolActive}"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Roll"
                                Content="Roll" />
                        <Button Classes="transport functional" Content="Move &lt;" Command="{Binding MoveLeftCommand}" />
                        <Button Classes="transport functional" Content="Move &gt;" Command="{Binding MoveRightCommand}" />
                        <Button Classes="transport functional" Content="Razor at Playhead" Command="{Binding SplitAtPlayheadCommand}" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsSnapEnabled}"
                                Command="{Binding ToggleSnapCommand}"
                                Content="Magnet" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsLinkedSelectionEnabled}"
                                Command="{Binding ToggleLinkedSelectionCommand}"
                                Content="Link" />
                        <Button Classes="transport functional" Content="Undo" Command="{Binding UndoCommand}" />
                        <Button Classes="transport functional" Content="Redo" Command="{Binding RedoCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="TracksWorkspacePanel"
                    Grid.Row="2"
                    Grid.ColumnSpan="3"
                    Classes="panel">
                <Grid RowDefinitions="Auto,Auto,*,56"
                      RowSpacing="8">
                    <TextBlock Classes="section-title" Text="VIDEO &amp; AUDIO TRACKS" />

                    <Border x:Name="CompactTimeRuler"
                            Grid.Row="1"
                            Classes="panel-muted"
                            Padding="4,2">
                        <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                            <Border Background="#0D131A"
                                    BorderBrush="#314055"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="6,2">
                                <TextBlock FontSize="10"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Text="Time Ruler" />
                            </Border>

                            <Grid Grid.Column="1" Height="16" ColumnDefinitions="*,*,*">
                                <TextBlock VerticalAlignment="Bottom"
                                           FontSize="9"
                                           HorizontalAlignment="Left"
                                           Text="{Binding TimelineRulerLeftLabel}" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Bottom"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Text="{Binding TimelineRulerCenterLabel}" />
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Bottom"
                                           FontSize="9"
                                           HorizontalAlignment="Right"
                                           Text="{Binding TimelineRulerRightLabel}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="V1LaneRow"
                            Grid.Row="2"
                            Classes="panel-muted"
                            Padding="10">
                        <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                            <Border Background="#0D131A"
                                    BorderBrush="#314055"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="6">
                                    <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="V1" />
                                    <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Video Lane" />
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Spacing="4">
                                        <Button Classes="transport functional"
                                                Classes.active-chip="{Binding IsTrackLockActive}"
                                                Padding="6,3"
                                                MinWidth="0"
                                                Command="{Binding ToggleTrackLockCommand}"
                                                Content="Lock" />
                                        <Button Classes="transport functional"
                                                Classes.active-chip="{Binding IsTrackMuteActive}"
                                                Padding="6,3"
                                                MinWidth="0"
                                                Command="{Binding ToggleTrackMuteCommand}"
                                                Content="Mute" />
                                        <Button Classes="transport functional"
                                                Classes.active-chip="{Binding IsTrackSoloActive}"
                                                Padding="6,3"
                                                MinWidth="0"
                                                Command="{Binding ToggleTrackSoloCommand}"
                                                Content="Solo" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Column="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <Grid Width="{Binding TimelinePreferredWidth}"
                                      MinHeight="180">
                                    <Canvas x:Name="TimelinePlayheadOverlayCanvas"
                                            Width="{Binding TimelinePreferredWidth}"
                                            Height="140">
                                        <ItemsControl Width="{Binding TimelinePreferredWidth}"
                                                      Height="140"
                                                      ItemsSource="{Binding TimelineBlocks}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas Width="{Binding TimelinePreferredWidth}"
                                                            Height="140" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:TimelineBlockItemViewModel">
                                                    <Button Width="{Binding WidthPixels}"
                                                            MinWidth="8"
                                                            Height="140"
                                                            Canvas.Left="{Binding LeftPixels}"
                                                            Canvas.Top="0"
                                                            Padding="0"
                                                            Cursor="Hand"
                                                            Focusable="False"
                                                            ToolTip.Tip="Select: klik za preview. Razor: klik za rez na V1."
                                                            PointerPressed="TimelineBlockPointerPressed"
                                                            PointerReleased="TimelineBlockPointerReleased"
                                                            Background="{Binding BackgroundBrush}"
                                                            Foreground="{Binding ForegroundBrush}"
                                                            BorderBrush="{Binding BorderBrush}"
                                                            BorderThickness="{Binding BorderThickness}">
                                                        <Grid RowDefinitions="Auto,*">
                                                            <Border x:Name="SelectedClipTitleBar"
                                                                    Background="{Binding TitleBarBackgroundBrush}"
                                                                    BorderBrush="{Binding TitleBarBorderBrush}"
                                                                    BorderThickness="0,0,0,1"
                                                                    CornerRadius="6,6,0,0"
                                                                    Padding="8,5">
                                                                <TextBlock FontSize="10"
                                                                           FontWeight="Bold"
                                                                           Text="{Binding SelectedTitleText}" />
                                                            </Border>

                                                            <Grid Grid.Row="1" ColumnDefinitions="10,*,10">
                                                                <Border x:Name="ClipHandleGripLeft"
                                                                        Width="6"
                                                                        Margin="2,8,0,8"
                                                                        Background="#9FB6CC"
                                                                        CornerRadius="3" />
                                                                <StackPanel Grid.Column="1" Margin="8" Spacing="6">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                                        <Border Background="{Binding AccentBrush}"
                                                                                BorderBrush="#E2E8F0"
                                                                                BorderThickness="1"
                                                                                CornerRadius="4"
                                                                                Padding="6,2">
                                                                            <TextBlock FontSize="10"
                                                                                       FontWeight="Bold"
                                                                                       Text="{Binding SelectionBadgeText}" />
                                                                        </Border>
                                                                        <TextBlock Grid.Column="1"
                                                                                   FontWeight="Bold"
                                                                                   VerticalAlignment="Center"
                                                                                   Text="{Binding Label}" />
                                                                        <Border Grid.Column="2"
                                                                                Background="#132334"
                                                                                BorderBrush="#6A88A6"
                                                                                BorderThickness="1"
                                                                                CornerRadius="4"
                                                                                Padding="5,2">
                                                                            <TextBlock FontSize="10" FontWeight="Bold" Text="SRC" />
                                                                        </Border>
                                                                    </Grid>
                                                                    <TextBlock FontSize="11"
                                                                               Text="{Binding Summary}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                                <Border x:Name="ClipHandleGripRight"
                                                                        Grid.Column="2"
                                                                        Width="6"
                                                                        Margin="0,8,2,8"
                                                                        Background="#9FB6CC"
                                                                        CornerRadius="3" />
                                                            </Grid>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border x:Name="TimelinePlayheadIndicator"
                                                Width="2"
                                                Canvas.Left="{Binding TimelinePlayheadOffsetPixels}"
                                                Canvas.Top="0"
                                                Background="#F97316"
                                                Height="140"
                                                IsHitTestVisible="False" />
                                    </Canvas>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border x:Name="A1LaneRow"
                            Grid.Row="3"
                            Classes="panel-muted"
                            Padding="10">
                        <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                            <Border Background="#0D131A"
                                    BorderBrush="#314055"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="4">
                                    <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="A1" />
                                    <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Audio Lane" />
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Column="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <Grid Width="{Binding TimelinePreferredWidth}"
                                      MinHeight="72">
                                    <Canvas Width="{Binding TimelinePreferredWidth}"
                                            Height="56">
                                        <ItemsControl Width="{Binding TimelinePreferredWidth}"
                                                      Height="56"
                                                      ItemsSource="{Binding TimelineBlocks}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas Width="{Binding TimelinePreferredWidth}"
                                                            Height="56" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:TimelineBlockItemViewModel">
                                                    <Border Width="{Binding WidthPixels}"
                                                            Height="56"
                                                            MinWidth="8"
                                                            Canvas.Left="{Binding LeftPixels}"
                                                            Canvas.Top="0"
                                                            Background="{Binding AudioBackgroundBrush}"
                                                            BorderBrush="{Binding AudioBorderBrush}"
                                                            BorderThickness="2"
                                                            CornerRadius="8"
                                                            Padding="12,8">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock FontWeight="Bold"
                                                                       Foreground="#F1FBF5"
                                                                       Text="{Binding Label}" />
                                                            <TextBlock FontSize="11"
                                                                       Foreground="#D8F6E3"
                                                                       Text="{Binding Summary}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

