<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VhsMp4Optimizer.App.ViewModels"
        xmlns:core="using:VhsMp4Optimizer.Core.Models"
        xmlns:controls="using:VhsMp4Optimizer.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="RootWindow"
        x:Class="VhsMp4Optimizer.App.Views.PlayerTrimWindow"
        x:DataType="vm:PlayerTrimWindowViewModel"
        Width="1440"
        Height="940"
        MinWidth="1200"
        MinHeight="780"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        Background="#14181F"
        Foreground="#E6EDF7">

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#1B222C" />
            <Setter Property="BorderBrush" Value="#2C3745" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style Selector="Border.panel-muted">
            <Setter Property="Background" Value="#111821" />
            <Setter Property="BorderBrush" Value="#2A3340" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F2F5F9" />
        </Style>

        <Style Selector="TextBlock.section-meta">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#96A4B8" />
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8FA2BA" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style Selector="Button.transport">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Background" Value="#283240" />
            <Setter Property="Foreground" Value="#EEF4FB" />
            <Setter Property="BorderBrush" Value="#314055" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.transport:pointerover">
            <Setter Property="Background" Value="#314155" />
            <Setter Property="BorderBrush" Value="#5B728D" />
        </Style>

        <Style Selector="Button.transport:pressed">
            <Setter Property="Background" Value="#0E7490" />
            <Setter Property="BorderBrush" Value="#22D3EE" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport:disabled">
            <Setter Property="Background" Value="#1A2430" />
            <Setter Property="BorderBrush" Value="#263240" />
            <Setter Property="Foreground" Value="#607086" />
            <Setter Property="Opacity" Value="0.82" />
        </Style>

        <Style Selector="Button.transport.active-chip">
            <Setter Property="Background" Value="#1E2A38" />
            <Setter Property="BorderBrush" Value="#40617F" />
            <Setter Property="Foreground" Value="#F5FAFF" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0E7490" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBox, ComboBox, NumericUpDown">
            <Setter Property="Background" Value="#0E151D" />
            <Setter Property="Foreground" Value="#EEF4FB" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,280" Margin="14">
        <StackPanel Spacing="12" Margin="0,0,0,14">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="Player / Trim" />
                    <TextBlock Classes="section-meta" Text="Non-linear editor mode" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Classes="panel-muted" Padding="10,6">
                            <TextBlock FontWeight="SemiBold" Text="Project" />
                        </Border>
                        <Border Classes="panel-muted" Padding="10,6">
                            <TextBlock FontWeight="SemiBold" Text="Sequence 01" />
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsCutModeActive}"
                                Content="Cut"
                                Command="{Binding SelectModeCommand}"
                                CommandParameter="Cut" />
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsEditModeActive}"
                                Content="Edit"
                                Command="{Binding SelectModeCommand}"
                                CommandParameter="Edit" />
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsColorModeActive}"
                                Content="Color"
                                Command="{Binding SelectModeCommand}"
                                CommandParameter="Color" />
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsDeliverModeActive}"
                                Content="Deliver"
                                Command="{Binding SelectModeCommand}"
                                CommandParameter="Deliver" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Classes="panel-muted"
                        Padding="12,8"
                        MinWidth="520">
                    <TextBlock Text="{Binding FileSummary}"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center" />
                </Border>

                <Button Grid.Column="2"
                        Classes="transport"
                        VerticalAlignment="Top"
                        Content="Back to Queue"
                        Click="ClosePlayerTrimClick" />
            </Grid>

            <Border Classes="panel-muted" Padding="12,10">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsMediaPoolActive}"
                                Content="Media Pool"
                                Command="{Binding SelectWorkspaceDockCommand}"
                                CommandParameter="Media Pool" />
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsEffectsLibraryActive}"
                                Content="Effects Library"
                                Command="{Binding SelectWorkspaceDockCommand}"
                                CommandParameter="Effects Library" />
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsEditIndexActive}"
                                Content="Edit Index"
                                Command="{Binding SelectWorkspaceDockCommand}"
                                CommandParameter="Edit Index" />
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsMixerActive}"
                                Content="Mixer"
                                Command="{Binding SelectWorkspaceDockCommand}"
                                CommandParameter="Mixer" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Classes="section-meta"
                               Text="Workspace chrome / dock status" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Border Classes="panel-muted" Padding="10,6">
                            <TextBlock FontWeight="SemiBold" Text="25 fps" />
                        </Border>
                        <Border Classes="panel-muted" Padding="10,6">
                            <TextBlock FontWeight="SemiBold" Text="Snap On" />
                        </Border>
                        <Border Classes="panel-muted" Padding="10,6">
                            <TextBlock FontWeight="SemiBold" Text="Linked Selection" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="92,*,360" ColumnSpacing="14">
            <Border Classes="panel">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               FontSize="12"
                               Text="Tool Rail" />

                    <Button Classes="transport"
                            Classes.active-chip="{Binding IsSelectToolActive}"
                            Padding="8"
                            Command="{Binding SelectToolCommand}"
                            CommandParameter="Select">
                        <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" Text="Select" />
                            <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Pointer" />
                        </StackPanel>
                    </Button>

                    <Button Classes="transport"
                            Classes.active-chip="{Binding IsBladeToolActive}"
                            Padding="8"
                            Command="{Binding SelectToolCommand}"
                            CommandParameter="Blade">
                        <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" Text="Blade" />
                            <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Cut" />
                        </StackPanel>
                    </Button>

                    <Button Classes="transport"
                            Classes.active-chip="{Binding IsSlipToolActive}"
                            Padding="8"
                            Command="{Binding SelectToolCommand}"
                            CommandParameter="Slip">
                        <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" Text="Slip" />
                            <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Shift" />
                        </StackPanel>
                    </Button>

                    <Button Classes="transport"
                            Classes.active-chip="{Binding IsRollToolActive}"
                            Padding="8"
                            Command="{Binding SelectToolCommand}"
                            CommandParameter="Roll">
                        <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" Text="Roll" />
                            <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Edge" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="panel">
                <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="transport"
                                        Classes.active-chip="{Binding IsSourceMonitorActive}"
                                        Content="Source"
                                        Command="{Binding SelectMonitorTabCommand}"
                                        CommandParameter="Source" />
                                <Button Classes="transport"
                                        Classes.active-chip="{Binding IsProgramMonitorActive}"
                                        Content="Program"
                                        Command="{Binding SelectMonitorTabCommand}"
                                        CommandParameter="Program" />
                                <Border Classes="panel-muted" Padding="10,6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Fit" />
                                        <TextBlock Text="100%" />
                                        <TextBlock Text="Safe" />
                                        <TextBlock Text="Proxy Off" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Classes="section-title" Text="Program Monitor" />
                                <TextBlock Classes="section-meta" Text="Playback i precizan trim kadar" />
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="panel-muted" Padding="10,6">
                            <TextBlock Text="{Binding PreviewSourceTimeText}" FontWeight="SemiBold" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#05080D"
                            BorderBrush="#293445"
                            BorderThickness="1"
                            CornerRadius="10"
                            ClipToBounds="True">
                        <Grid>
                            <controls:EmbeddedVideoView x:Name="PlaybackVideoView"
                                                        MediaPlayer="{Binding PlaybackMediaPlayerBinding}"
                                                        IsVisible="{Binding IsVideoPlaybackVisible}"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch" />
                            <Image Source="{Binding PreviewBitmap}"
                                   IsVisible="{Binding IsPreviewImageVisible}"
                                   IsHitTestVisible="False"
                                   Stretch="Uniform" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10">
                        <TextBlock VerticalAlignment="Center" Classes="field-label" Text="Virtual" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding PreviewVirtualTimeText}" />
                        <Slider Grid.Column="2"
                                Minimum="0"
                                Maximum="{Binding PreviewVirtualMaximum}"
                                Value="{Binding PreviewVirtualSeconds, Mode=TwoWay}"
                                PointerPressed="PreviewSliderPointerPressed"
                                PointerReleased="PreviewSliderPointerReleased" />
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding PreviewSourceTimeText}" />
                    </Grid>

                    <Border Grid.Row="3" Classes="panel-muted">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="field-label" Text="Navigate" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Classes="transport" Content="START" Command="{Binding GoToStartCommand}" />
                                        <Button Classes="transport" Content="&lt;&lt;&lt;" Command="{Binding Back250FramesCommand}" />
                                        <Button Classes="transport" Content="&lt;&lt;" Command="{Binding Back25FramesCommand}" />
                                        <Button Classes="transport" Content="&lt;" Command="{Binding BackFrameCommand}" />
                                        <Button Classes="transport" Content="&gt;" Command="{Binding ForwardFrameCommand}" />
                                        <Button Classes="transport" Content="&gt;&gt;" Command="{Binding Forward25FramesCommand}" />
                                        <Button Classes="transport" Content="&gt;&gt;&gt;" Command="{Binding Forward250FramesCommand}" />
                                        <Button Classes="transport" Content="END" Command="{Binding GoToEndCommand}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Classes="field-label" Text="Playback" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Classes="transport" Content="Play" Command="{Binding PlayCommand}" />
                                        <Button Classes="transport" Content="Pause" Command="{Binding PauseCommand}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Classes="field-label" Text="Marks" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Classes="transport" Content="In" Command="{Binding SetInPointCommand}" />
                                        <Button Classes="transport" Content="Out" Command="{Binding SetOutPointCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="10">
                        <TextBlock VerticalAlignment="Center" Text="IN Point" />
                        <TextBox Grid.Column="1" Text="{Binding InPointText}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="OUT Point" />
                        <TextBox Grid.Column="3" Text="{Binding OutPointText}" />
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2" Spacing="12">
                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-title" Text="Inspector" />
                        <TextBlock Classes="section-meta" Text="Odabrani segment, crop i timeline komande" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="transport"
                                    Classes.active-chip="{Binding IsVideoInspectorActive}"
                                    Content="Video"
                                    Command="{Binding SelectInspectorTabCommand}"
                                    CommandParameter="Video" />
                            <Button Classes="transport"
                                    Classes.active-chip="{Binding IsAudioInspectorActive}"
                                    Content="Audio"
                                    Command="{Binding SelectInspectorTabCommand}"
                                    CommandParameter="Audio" />
                            <Button Classes="transport"
                                    Classes.active-chip="{Binding IsEffectsInspectorActive}"
                                    Content="Effects"
                                    Command="{Binding SelectInspectorTabCommand}"
                                    CommandParameter="Effects" />
                        </StackPanel>

                        <Border Classes="panel-muted">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="field-label" Text="Timeline Info" />
                                <TextBlock Text="{Binding TimelineSummary}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding FileSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Classes="transport" Content="Save to Queue" Command="{Binding SaveToQueueCommand}" />
                            <Button Grid.Column="1" Classes="transport" Content="Close All Gaps" Command="{Binding CloseAllGapsCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-title" Text="Transform" />

                        <Grid ColumnDefinitions="110,*" ColumnSpacing="10">
                            <TextBlock VerticalAlignment="Center" Text="Aspect" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding AspectModes}" SelectedItem="{Binding SelectedAspectMode}" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,70,Auto,70" ColumnSpacing="8">
                            <TextBlock VerticalAlignment="Center" Text="Crop L" />
                            <NumericUpDown Grid.Column="1" Value="{Binding CropLeft}" Minimum="0" Maximum="2000" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Crop T" />
                            <NumericUpDown Grid.Column="3" Value="{Binding CropTop}" Minimum="0" Maximum="2000" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,70,Auto,70" ColumnSpacing="8">
                            <TextBlock VerticalAlignment="Center" Text="Crop R" />
                            <NumericUpDown Grid.Column="1" Value="{Binding CropRight}" Minimum="0" Maximum="2000" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Crop B" />
                            <NumericUpDown Grid.Column="3" Value="{Binding CropBottom}" Minimum="0" Maximum="2000" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Classes="transport" Content="Detect Crop" Command="{Binding DetectCropCommand}" />
                            <Button Grid.Column="1" Classes="transport" Content="Auto Crop" Command="{Binding AutoCropCommand}" />
                            <Button Grid.Column="2" Classes="transport" Content="Clear Crop" Command="{Binding ClearCropCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-title" Text="Metadata" />
                        <ListBox ItemsSource="{Binding Segments}" SelectedItem="{Binding SelectedSegment}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="core:TimelineSegment">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="8"
                                            Background="#101720"
                                            BorderBrush="#2A3644"
                                            BorderThickness="1">
                                        <Grid ColumnDefinitions="70,*,Auto" RowDefinitions="Auto,Auto">
                                            <TextBlock FontWeight="Bold" Text="{Binding Kind}" />
                                            <TextBlock Grid.Column="1" Text="{Binding TimelineStartSeconds, StringFormat='Timeline {0:0.00}s'}" />
                                            <TextBlock Grid.Column="2" Text="{Binding DurationSeconds, StringFormat='Trajanje {0:0.00}s'}" />
                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Margin="0,6,0,0"
                                                       Text="{Binding SourceStartSeconds, StringFormat='Source {0:0.00}s'}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,6,0,0"
                                                       Text="{Binding SourceEndSeconds, StringFormat='do {0:0.00}s'}"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Classes="panel" Margin="0,14,0,0">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                        <TextBlock Classes="section-title" Text="Timeline" />
                        <TextBlock Classes="section-meta" Text="Track view i edit akcije" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Border Classes="panel-muted" Padding="10,6">
                            <TextBlock Text="{Binding TimelineSummary}" />
                        </Border>
                        <Border Classes="panel-muted" Padding="10,6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Timeline Controls" />
                                <TextBlock Text="Magnet" />
                                <TextBlock Text="Link" />
                                <TextBlock Text="Zoom -" />
                                <TextBlock Text="Zoom +" />
                                <Button Classes="transport"
                                        Classes.active-chip="{Binding IsZoom1sActive}"
                                        Command="{Binding SelectZoomPresetCommand}"
                                        CommandParameter="1s"
                                        Content="1s" />
                                <Button Classes="transport"
                                        Classes.active-chip="{Binding IsZoom5sActive}"
                                        Command="{Binding SelectZoomPresetCommand}"
                                        CommandParameter="5s"
                                        Content="5s" />
                                <Button Classes="transport"
                                        Classes.active-chip="{Binding IsZoom10sActive}"
                                        Command="{Binding SelectZoomPresetCommand}"
                                        CommandParameter="10s"
                                        Content="10s" />
                                <Button Classes="transport"
                                        Classes.active-chip="{Binding IsZoomFullActive}"
                                        Command="{Binding SelectZoomPresetCommand}"
                                        CommandParameter="Full"
                                        Content="Full" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Classes="panel-muted" Padding="10,8">
                    <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                        <Border Classes="panel"
                                Padding="8"
                                CornerRadius="6"
                                Background="#0D131A"
                                BorderBrush="#314055">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="Time Ruler" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Source" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,*" ColumnSpacing="16">
                            <Border x:Name="TimelinePlayheadBadge"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Background="#0E7490"
                                    BorderBrush="#22D3EE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,4"
                                    Margin="0,0,0,6">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewVirtualTimeText}" />
                            </Border>
                            <Border Grid.Row="1" Background="#0C131D" BorderBrush="#314055" BorderThickness="0,0,0,1" Padding="8,4">
                                <TextBlock HorizontalAlignment="Left" Text="00:00" />
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Background="#0C131D" BorderBrush="#314055" BorderThickness="0,0,0,1" Padding="8,4">
                                <TextBlock HorizontalAlignment="Center" Text="00:30" />
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" Background="#0C131D" BorderBrush="#314055" BorderThickness="0,0,0,1" Padding="8,4">
                                <TextBlock HorizontalAlignment="Right" Text="01:00" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Classes="panel-muted">
                    <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                        <Border Classes="panel"
                                Padding="8"
                                CornerRadius="6"
                                Background="#0D131A"
                                BorderBrush="#314055">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="Marker Rail" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Cuts" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Border Classes="panel-muted" Padding="10,6">
                                <TextBlock Text="Mark In" />
                            </Border>
                            <Border Classes="panel-muted" Padding="10,6">
                                <TextBlock Text="Mark Out" />
                            </Border>
                            <Border Classes="panel-muted" Padding="10,6">
                                <TextBlock Text="Prev Cut" />
                            </Border>
                            <Border Classes="panel-muted" Padding="10,6">
                                <TextBlock Text="Next Cut" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Classes="panel-muted">
                    <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                        <Border Classes="panel"
                                Padding="8"
                                CornerRadius="6"
                                Background="#0D131A"
                                BorderBrush="#314055">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="V1" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Track" />
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                    <Button Classes="transport"
                                            Classes.active-chip="{Binding IsTrackLockActive}"
                                            Padding="6,3"
                                            MinWidth="0"
                                            Command="{Binding ToggleTrackLockCommand}"
                                            Content="Lock" />
                                    <Button Classes="transport"
                                            Classes.active-chip="{Binding IsTrackMuteActive}"
                                            Padding="6,3"
                                            MinWidth="0"
                                            Command="{Binding ToggleTrackMuteCommand}"
                                            Content="Mute" />
                                    <Button Classes="transport"
                                            Classes.active-chip="{Binding IsTrackSoloActive}"
                                            Padding="6,3"
                                            MinWidth="0"
                                            Command="{Binding ToggleTrackSoloCommand}"
                                            Content="Solo" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding TimelineBlocks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TimelineBlockItemViewModel">
                                            <Button Width="{Binding WidthPixels}"
                                                    MinWidth="96"
                                                    Height="92"
                                                    Padding="0"
                                                    Command="{Binding DataContext.SelectTimelineBlockCommand, ElementName=RootWindow}"
                                                    CommandParameter="{Binding .}"
                                                    Background="{Binding BackgroundBrush}"
                                                    Foreground="{Binding ForegroundBrush}"
                                                    BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="{Binding BorderThickness}">
                                                <StackPanel Margin="8" Spacing="4">
                                                    <Grid ColumnDefinitions="Auto,*">
                                                        <Border Background="#0F1720" BorderBrush="#5C6C7F" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                                            <TextBlock FontSize="10" FontWeight="Bold" Text="CLIP" />
                                                        </Border>
                                                        <TextBlock Grid.Column="1"
                                                                   Margin="8,0,0,0"
                                                                   FontWeight="Bold"
                                                                   VerticalAlignment="Center"
                                                                   Text="{Binding Label}" />
                                                    </Grid>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap" Text="{Binding Summary}" />
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <TextBlock FontSize="10" FontWeight="Bold" Text="DUR" />
                                                        <TextBlock Grid.Column="1" FontSize="10" Text="{Binding Summary}" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border x:Name="TimelinePlayheadIndicator"
                                    Width="2"
                                    Background="#22D3EE"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch"
                                    IsHitTestVisible="False" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Classes="panel-muted">
                    <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                        <Border Classes="panel"
                                Padding="8"
                                CornerRadius="6"
                                Background="#0D131A"
                                BorderBrush="#314055">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="A1" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Waveform" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#0F151E"
                                BorderBrush="#263444"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,14">
                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10" VerticalAlignment="Center">
                                <Border Background="#1F4C63" Height="28" CornerRadius="4" VerticalAlignment="Center" Opacity="0.85" />
                                <Border Grid.Column="1" Background="#2A607A" Height="40" CornerRadius="4" VerticalAlignment="Center" Opacity="0.85" />
                                <Border Grid.Column="2" Background="#1F4C63" Height="22" CornerRadius="4" VerticalAlignment="Center" Opacity="0.85" />
                                <Border Grid.Column="3" Background="#2A607A" Height="34" CornerRadius="4" VerticalAlignment="Center" Opacity="0.85" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="5" Spacing="8">
                    <TextBlock Classes="field-label" Text="Edit Tools" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="transport" Content="Split at Playhead" Command="{Binding SplitAtPlayheadCommand}" />
                        <Button Classes="transport" Content="Toggle Keep/Cut" Command="{Binding ToggleKeepCutCommand}" />
                        <Button Classes="transport" Content="Trim Selected" Command="{Binding TrimSelectedToInOutCommand}" />
                        <Button Classes="transport" Content="Extract Selected" Command="{Binding ExtractSelectedToInOutCommand}" />
                        <Button Classes="transport" Content="Duplicate Selected" Command="{Binding DuplicateSelectedCommand}" />
                        <Button Classes="transport" Content="Merge With Next" Command="{Binding MergeWithNextCommand}" />
                        <Button Classes="transport" Content="Roll &lt;" Command="{Binding RollLeftCommand}" />
                        <Button Classes="transport" Content="Roll &gt;" Command="{Binding RollRightCommand}" />
                        <Button Classes="transport" Content="Insert 1s Gap" Command="{Binding InsertGapAtPlayheadCommand}" />
                        <Button Classes="transport" Content="Undo" Command="{Binding UndoCommand}" />
                        <Button Classes="transport" Content="Redo" Command="{Binding RedoCommand}" />
                        <Button Classes="transport" Content="Slip &lt;" Command="{Binding SlipLeftCommand}" />
                        <Button Classes="transport" Content="Slip &gt;" Command="{Binding SlipRightCommand}" />
                        <Button Classes="transport" Content="Cut Segment" Command="{Binding CutSegmentCommand}" />
                        <Button Classes="transport" Content="Delete" Command="{Binding DeleteSegmentCommand}" />
                        <Button Classes="transport" Content="Ripple Delete" Command="{Binding RippleDeleteCommand}" />
                        <Button Classes="transport" Content="Move Left" Command="{Binding MoveLeftCommand}" />
                        <Button Classes="transport" Content="Move Right" Command="{Binding MoveRightCommand}" />
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <Border Grid.Row="6" Classes="panel-muted">
                    <Grid ColumnDefinitions="2.2*,1.2*,1*" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="field-label" Text="Selection" />
                            <TextBlock Text="{Binding EditorHint}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Classes="field-label" Text="Playhead" />
                            <TextBlock Text="{Binding PreviewVirtualTimeText}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Classes="field-label" Text="Mode" />
                            <TextBlock Text="Trim / Timeline" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
