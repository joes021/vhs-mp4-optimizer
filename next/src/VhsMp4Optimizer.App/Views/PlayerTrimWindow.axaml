<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VhsMp4Optimizer.App.ViewModels"
        xmlns:core="using:VhsMp4Optimizer.Core.Models"
        xmlns:controls="using:VhsMp4Optimizer.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="RootWindow"
        x:Class="VhsMp4Optimizer.App.Views.PlayerTrimWindow"
        x:DataType="vm:PlayerTrimWindowViewModel"
        Width="1560"
        Height="1020"
        MinWidth="1200"
        MinHeight="820"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        Background="#14181F"
        Foreground="#E6EDF7">

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#1B222C" />
            <Setter Property="BorderBrush" Value="#2C3745" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style Selector="Border.panel-muted">
            <Setter Property="Background" Value="#111821" />
            <Setter Property="BorderBrush" Value="#2A3340" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F2F5F9" />
        </Style>

        <Style Selector="TextBlock.section-meta">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#96A4B8" />
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8FA2BA" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style Selector="Button.transport">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Background" Value="#283240" />
            <Setter Property="Foreground" Value="#EEF4FB" />
            <Setter Property="BorderBrush" Value="#314055" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.transport:pointerover">
            <Setter Property="Background" Value="#25543A" />
            <Setter Property="BorderBrush" Value="#6DB087" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport:pressed">
            <Setter Property="Background" Value="#1A412C" />
            <Setter Property="BorderBrush" Value="#98D6AF" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport:disabled">
            <Setter Property="Background" Value="#2B3A4D" />
            <Setter Property="BorderBrush" Value="#42546A" />
            <Setter Property="Foreground" Value="#A7BDD4" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.transport.active-chip">
            <Setter Property="Background" Value="#405876" />
            <Setter Property="BorderBrush" Value="#A6BCD3" />
            <Setter Property="Foreground" Value="#F5FAFF" />
        </Style>

        <Style Selector="Button.transport.functional">
            <Setter Property="Background" Value="#1E6F3D" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#8BE0A6" />
        </Style>

        <Style Selector="Button.transport.functional:pointerover">
            <Setter Property="Background" Value="#245E38" />
            <Setter Property="BorderBrush" Value="#B1F2C4" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport.functional:pressed">
            <Setter Property="Background" Value="#194A2B" />
            <Setter Property="BorderBrush" Value="#D2FADB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport.functional.active-chip">
            <Setter Property="Background" Value="#227B44" />
            <Setter Property="BorderBrush" Value="#C8F5D7" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport.functional:disabled">
            <Setter Property="Background" Value="#2B3A4D" />
            <Setter Property="BorderBrush" Value="#42546A" />
            <Setter Property="Foreground" Value="#A7BDD4" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.transport:disabled /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="#A7BDD4" />
        </Style>

        <Style Selector="Button.transport.functional:disabled /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="#A7BDD4" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0E7490" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBox, ComboBox, NumericUpDown">
            <Setter Property="Background" Value="#0E151D" />
            <Setter Property="Foreground" Value="#EEF4FB" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="14" RowSpacing="14">
        <StackPanel Grid.Row="0" Spacing="10">
            <Border Classes="panel-muted" Padding="10,8">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <TextBlock Classes="field-label"
                               VerticalAlignment="Center"
                               Text="DaVinci-like Menu" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <Button Classes="transport" Content="File" />
                        <Button Classes="transport" Content="Edit" />
                        <Button Classes="transport" Content="Trim" />
                        <Button Classes="transport" Content="Timeline" />
                        <Button Classes="transport" Content="Clip" />
                        <Button Classes="transport" Content="Mark" />
                        <Button Classes="transport" Content="View" />
                        <Button Classes="transport" Content="Playback" />
                        <Button Classes="transport" Content="Workspace" />
                        <Button Classes="transport" Content="Help" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="panel-muted" Padding="12,10">
                <Grid ColumnDefinitions="250,*,320" ColumnSpacing="18">
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Player / Trim" />
                        <TextBlock Classes="field-label" Text="Session Status" />
                        <TextBlock Classes="section-meta" Text="Non-linear editor mode" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="panel-muted" Padding="10,6">
                                <TextBlock FontWeight="SemiBold" Text="Project" />
                            </Border>
                            <Border Classes="panel-muted" Padding="10,6">
                                <TextBlock FontWeight="SemiBold" Text="Sequence 01" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsCutModeActive}"
                                    Content="Cut"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="Cut" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsEditModeActive}"
                                    Content="Edit"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="Edit" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsColorModeActive}"
                                    Content="Color"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="Color" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsDeliverModeActive}"
                                    Content="Deliver"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="Deliver" />
                        </StackPanel>
                        <Border Classes="panel-muted" Padding="12,8">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Timeline 01" />
                                    <TextBlock Classes="section-meta" Text="|" />
                                    <TextBlock Text="Record Monitor" />
                                </StackPanel>
                                <TextBlock HorizontalAlignment="Center"
                                           Text="{Binding FileSummary}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="field-label" VerticalAlignment="Center" Text="Timeline View" />
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Spacing="8">
                                <Button Classes="transport active-chip" Content="Single Viewer" />
                                <Button Classes="transport" Content="Dual Viewer" />
                                <Button Classes="transport" Content="Inspector Right" />
                                <Button Classes="transport" Content="Mixer Right" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Classes="section-meta"
                                       VerticalAlignment="Center"
                                       Text="Workspace chrome / dock status" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="8" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Classes="transport active-chip" Content="Edited" />
                            <Button Classes="transport" Content="Auto Save" />
                        </StackPanel>
                        <Button Classes="transport functional"
                                HorizontalAlignment="Right"
                                Content="Back to Queue"
                                Click="ClosePlayerTrimClick" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Grid x:Name="EditorMockupGrid"
              Grid.Row="1"
              RowDefinitions="*,Auto,Auto,*"
              ColumnDefinitions="250,*,320"
              ColumnSpacing="14"
              RowSpacing="14">
            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Classes="panel">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Classes="section-title" Text="Media Pool" />
                        <TextBlock Classes="section-meta" Text="MEDIA FILES" />
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <TextBlock Classes="field-label" VerticalAlignment="Center" Text="Browser" />
                        <WrapPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Classes="transport active-chip functional"
                                    Content="Clips"
                                    Command="{Binding SelectWorkspaceDockCommand}"
                                    CommandParameter="Media Pool" />
                            <Button Classes="transport" Content="Timelines" />
                            <Button Classes="transport" Content="Smart Bins" />
                            <Button Classes="transport" Content="Filter" />
                            <Button Classes="transport" Content="Scene" />
                            <Button Classes="transport" Content="Reel" />
                        </WrapPanel>
                    </Grid>

                    <WrapPanel Orientation="Horizontal">
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsMediaPoolActive}"
                                Content="Media Pool"
                                Command="{Binding SelectWorkspaceDockCommand}"
                                CommandParameter="Media Pool" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsEffectsLibraryActive}"
                                Content="Effects Library"
                                Command="{Binding SelectWorkspaceDockCommand}"
                                CommandParameter="Effects Library" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsEditIndexActive}"
                                Content="Edit Index"
                                Command="{Binding SelectWorkspaceDockCommand}"
                                CommandParameter="Edit Index" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsMixerActive}"
                                Content="Mixer"
                                Command="{Binding SelectWorkspaceDockCommand}"
                                CommandParameter="Mixer" />
                    </WrapPanel>

                    <Grid ColumnDefinitions="92,*" ColumnSpacing="10">
                        <Border Classes="panel-muted"
                                Padding="10"
                                Background="#121A24">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="field-label" Text="Bins" />
                                <Border Background="#1A2430"
                                        BorderBrush="#324153"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6">
                                    <TextBlock FontWeight="SemiBold" Text="Master" />
                                </Border>
                                <Border Background="#101822"
                                        BorderBrush="#2A394D"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6">
                                    <TextBlock Text="Smart Bins" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="10">
                            <TextBlock Classes="field-label" Text="Clips" />
                            <WrapPanel Orientation="Horizontal" ItemWidth="64" ItemHeight="30">
                                <Button Classes="transport" Content="Sort" />
                                <Button Classes="transport" Content="View" />
                                <Button Classes="transport" Content="Metadata" />
                            </WrapPanel>
                            <Border Classes="panel-muted"
                                    Padding="8"
                                    Background="#181F29"
                                    BorderBrush="#395170">
                                <StackPanel Spacing="6">
                                    <Border Height="62"
                                            CornerRadius="6"
                                            Background="#2B394A"
                                            BorderBrush="#4F6B87"
                                            BorderThickness="1" />
                                    <TextBlock FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding Item.SourceFile}" />
                                    <TextBlock Classes="section-meta" Text="Source Clip" />
                                </StackPanel>
                            </Border>
                            <Border Classes="panel-muted"
                                    Padding="8,6"
                                    Background="#141C26"
                                    BorderBrush="#395170">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Classes="field-label" Text="Clip Info" />
                                    <TextBlock Grid.Column="1" Text="Date Shot" />
                                    <TextBlock Grid.Row="1" Classes="field-label" Text="Reel Name" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Master" />
                                    <TextBlock Grid.Row="2" Classes="field-label" Text="Camera" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="DV Cam" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Classes="panel">
                <Grid x:Name="CenterMonitorGrid" RowDefinitions="Auto,420,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsSourceMonitorActive}"
                                    Content="Source"
                                    Command="{Binding SelectMonitorTabCommand}"
                                    CommandParameter="Source" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsProgramMonitorActive}"
                                    Content="Program"
                                    Command="{Binding SelectMonitorTabCommand}"
                                    CommandParameter="Program" />
                            <Border Classes="panel-muted" Padding="10,6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Monitor HUD" />
                                    <TextBlock Classes="section-meta" Text="Program" />
                                </StackPanel>
                            </Border>
                            <Border Classes="panel-muted" Padding="10,6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Fit" />
                                    <TextBlock Text="100%" />
                                    <TextBlock Text="Safe" />
                                    <TextBlock Text="Proxy Off" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="2"
                                    HorizontalAlignment="Center">
                            <TextBlock Classes="section-title"
                                       HorizontalAlignment="Center"
                                       Text="Program Monitor" />
                            <TextBlock Classes="section-meta"
                                       HorizontalAlignment="Center"
                                       Text="VIDEO" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="8">
                            <Border Classes="panel-muted" Padding="10,6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Classes="field-label" Margin="0" Text="Duration" />
                                    <TextBlock FontWeight="SemiBold" Text="{Binding PreviewDurationText}" />
                                </StackPanel>
                            </Border>
                            <Border Classes="panel-muted" Padding="10,6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="25 fps" />
                                    <Button Classes="transport functional"
                                            Classes.active-chip="{Binding IsSnapEnabled}"
                                            Content="{Binding SnapStatusText}"
                                            Command="{Binding ToggleSnapCommand}" />
                                    <Border Classes="panel-muted" Padding="8,4">
                                        <TextBlock FontWeight="SemiBold" Text="Linked Selection" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border x:Name="PrimaryProgramMonitor"
                            Grid.Row="1"
                            Height="420"
                            Background="#05080D"
                            BorderBrush="#293445"
                            BorderThickness="1"
                            CornerRadius="10"
                            ClipToBounds="True">
                        <Grid RowDefinitions="Auto,*">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  Margin="14,12,14,0"
                                  ColumnSpacing="12">
                                <Border Classes="panel-muted"
                                        Padding="10,6"
                                        Background="#0D1621">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="Monitor HUD" />
                                        <TextBlock Classes="section-meta" Text="Program" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#D3DCE8"
                                           Text="Preview / playback viewport" />
                                <Border Grid.Column="2"
                                        Classes="panel-muted"
                                        Padding="10,6"
                                        Background="#0D1621">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding PreviewVirtualTimeText}" />
                                </Border>
                            </Grid>

                            <Border x:Name="ProgramMonitorViewport"
                                    Grid.Row="1"
                                    Height="360"
                                    Margin="16,10,16,16"
                                    Background="#05080D"
                                    BorderBrush="#293445"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    ClipToBounds="True">
                                <Grid>
                                    <controls:EmbeddedVideoView x:Name="PlaybackVideoView"
                                                                MediaPlayer="{Binding PlaybackMediaPlayerBinding}"
                                                                IsVisible="{Binding IsVideoPlaybackVisible}"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch" />
                                    <Image Source="{Binding PreviewBitmap}"
                                           IsVisible="{Binding IsPreviewImageVisible}"
                                           IsHitTestVisible="False"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Stretch="Uniform" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="PreviewScrubBar" Grid.Row="2" Classes="panel-muted" Padding="12,8">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{Binding PreviewVirtualTimeText}" />
                            <Slider Grid.Column="1"
                                    Minimum="0"
                                    Maximum="{Binding PreviewVirtualMaximum}"
                                    Value="{Binding PreviewVirtualSeconds, Mode=TwoWay}"
                                    PointerPressed="PreviewSliderPointerPressed"
                                    PointerReleased="PreviewSliderPointerReleased" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="MonitorTransportBand"
                    Grid.Row="1"
                    Grid.Column="1"
                    Classes="panel"
                    Padding="12,10">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="field-label" VerticalAlignment="Center" Text="Playback Controls" />
                        <Button Classes="transport" Content="Shuttle -" />
                        <Button Classes="transport functional" Content="Stop" Command="{Binding PauseCommand}" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsLoopPlaybackEnabled}"
                                Content="Loop"
                                Command="{Binding ToggleLoopPlaybackCommand}" />
                        <Button Classes="transport" Content="Shuttle +" />
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="18">
                        <TextBlock Classes="field-label" Grid.Column="0" Text="Navigate" />
                        <TextBlock Classes="field-label" Grid.Column="1" Text="Playback" />
                        <TextBlock Classes="field-label" Grid.Column="2" Text="Marks" />
                    </Grid>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="transport functional" Content="START" Command="{Binding GoToStartCommand}" />
                                <Button Classes="transport functional" Content="&lt;&lt;&lt;" Command="{Binding Back250FramesCommand}" />
                                <Button Classes="transport functional" Content="&lt;&lt;" Command="{Binding Back25FramesCommand}" />
                                <Button Classes="transport functional" Content="&lt;" Command="{Binding BackFrameCommand}" />
                                <Button Classes="transport functional" Content="&gt;" Command="{Binding ForwardFrameCommand}" />
                                <Button Classes="transport functional" Content="&gt;&gt;" Command="{Binding Forward25FramesCommand}" />
                                <Button Classes="transport functional" Content="&gt;&gt;&gt;" Command="{Binding Forward250FramesCommand}" />
                                <Button Classes="transport functional" Content="END" Command="{Binding GoToEndCommand}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="transport functional" Content="Play" Command="{Binding PlayCommand}" />
                                <Button Classes="transport functional" Content="Pause" Command="{Binding PauseCommand}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="transport functional" Content="In" Command="{Binding SetInPointCommand}" />
                                <Button Classes="transport functional" Content="Out" Command="{Binding SetOutPointCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="10">
                        <TextBlock VerticalAlignment="Center" Text="IN Point" />
                        <TextBox Grid.Column="1" Text="{Binding InPointText}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="OUT Point" />
                        <TextBox Grid.Column="3" Text="{Binding OutPointText}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Classes="panel">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="section-title" Text="Inspector" />
                        <TextBlock Classes="section-meta" Text="Odabrani segment, crop i timeline komande" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <TextBlock Classes="field-label"
                                       VerticalAlignment="Center"
                                       Text="Inspector Stack" />
                            <WrapPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Classes="transport" Content="Bypass" />
                                <Button Classes="transport" Content="Reset All" />
                                <Button Classes="transport" Content="Copy" />
                                <Button Classes="transport" Content="Paste" />
                            </WrapPanel>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <TextBlock Classes="field-label"
                                       VerticalAlignment="Center"
                                       Text="Section Status" />
                            <WrapPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Classes="transport" Content="Open" />
                                <Button Classes="transport" Content="Keyframed" />
                                <Button Classes="transport" Content="Bypassed" />
                            </WrapPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsVideoInspectorActive}"
                                    Content="Video"
                                    Command="{Binding SelectInspectorTabCommand}"
                                    CommandParameter="Video" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsAudioInspectorActive}"
                                    Content="Audio"
                                    Command="{Binding SelectInspectorTabCommand}"
                                    CommandParameter="Audio" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsEffectsInspectorActive}"
                                    Content="Effects"
                                    Command="{Binding SelectInspectorTabCommand}"
                                    CommandParameter="Effects" />
                        </StackPanel>

                        <Border Classes="panel-muted">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="field-label" Text="Timeline Info" />
                                <TextBlock Text="{Binding TimelineSummary}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding FileSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Classes="transport functional"
                                    Content="Save to Queue"
                                    Command="{Binding SaveToQueueCommand}" />
                            <Button Grid.Column="1"
                                    Classes="transport functional"
                                    Content="Close All Gaps"
                                    Command="{Binding CloseAllGapsCommand}" />
                        </Grid>

                        <TextBlock Classes="section-title" Text="Transform" />
                        <Border Classes="panel-muted">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Classes="panel-muted" Padding="8,4">
                                        <TextBlock FontWeight="SemiBold" Text="Transform Reset" />
                                    </Border>
                                    <Border Classes="panel-muted" Padding="8,4">
                                        <TextBlock FontWeight="SemiBold" Text="Keyframe" />
                                    </Border>
                                </StackPanel>
                                <Grid ColumnDefinitions="Auto,70,Auto,70" ColumnSpacing="8">
                                    <TextBlock VerticalAlignment="Center" Text="Zoom X" />
                                    <TextBox Grid.Column="1" Text="1.000" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Zoom Y" />
                                    <TextBox Grid.Column="3" Text="1.000" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,70,Auto,70" ColumnSpacing="8">
                                    <TextBlock VerticalAlignment="Center" Text="Position X" />
                                    <TextBox Grid.Column="1" Text="0.000" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Position Y" />
                                    <TextBox Grid.Column="3" Text="0.000" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Classes="field-label" Text="Cropping" />
                        <Grid ColumnDefinitions="110,*" ColumnSpacing="10">
                            <TextBlock VerticalAlignment="Center" Text="Aspect" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AspectModes}"
                                      SelectedItem="{Binding SelectedAspectMode}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,70,Auto,70" ColumnSpacing="8">
                            <TextBlock VerticalAlignment="Center" Text="Crop L" />
                            <NumericUpDown Grid.Column="1" Value="{Binding CropLeft}" Minimum="0" Maximum="2000" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Crop T" />
                            <NumericUpDown Grid.Column="3" Value="{Binding CropTop}" Minimum="0" Maximum="2000" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,70,Auto,70" ColumnSpacing="8">
                            <TextBlock VerticalAlignment="Center" Text="Crop R" />
                            <NumericUpDown Grid.Column="1" Value="{Binding CropRight}" Minimum="0" Maximum="2000" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Crop B" />
                            <NumericUpDown Grid.Column="3" Value="{Binding CropBottom}" Minimum="0" Maximum="2000" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Classes="transport functional" Content="Detect Crop" Command="{Binding DetectCropCommand}" />
                            <Button Grid.Column="1" Classes="transport functional" Content="Auto Crop" Command="{Binding AutoCropCommand}" />
                            <Button Grid.Column="2" Classes="transport functional" Content="Clear Crop" Command="{Binding ClearCropCommand}" />
                        </Grid>

                        <TextBlock Classes="field-label" Text="Composite" />
                        <Border Classes="panel-muted">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <TextBlock VerticalAlignment="Center" Text="Mode" />
                                <TextBox Grid.Column="1" Text="Normal" />
                            </Grid>
                        </Border>

                        <TextBlock Classes="field-label" Text="Retime &amp; Scaling" />
                        <Border Classes="panel-muted">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <TextBlock VerticalAlignment="Center" Text="Speed" />
                                <TextBox Grid.Column="1" Text="100.00%" />
                            </Grid>
                        </Border>

                        <TextBlock Classes="section-title" Text="Metadata" />
                        <TextBlock Classes="section-meta" Text="Selected Clip" />
                        <ListBox ItemsSource="{Binding Segments}"
                                 SelectedItem="{Binding SelectedSegment}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="core:TimelineSegment">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="8"
                                            Background="#101720"
                                            BorderBrush="#2A3644"
                                            BorderThickness="1">
                                        <Grid ColumnDefinitions="70,*,Auto" RowDefinitions="Auto,Auto">
                                            <TextBlock FontWeight="Bold" Text="{Binding Kind}" />
                                            <TextBlock Grid.Column="1" Text="{Binding TimelineStartSeconds, StringFormat='Timeline {0:0.00}s'}" />
                                            <TextBlock Grid.Column="2" Text="{Binding DurationSeconds, StringFormat='Trajanje {0:0.00}s'}" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.ColumnSpan="3"
                                                       Margin="0,6,0,0"
                                                       Text="{Binding SourceStartSeconds, StringFormat='Source {0:0.00}s'}" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="1"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,6,0,0"
                                                       HorizontalAlignment="Right"
                                                       Text="{Binding SourceEndSeconds, StringFormat='do {0:0.00}s'}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="TrackToolsBar"
                    Grid.Row="2"
                    Grid.ColumnSpan="3"
                    Classes="panel-muted"
                    Padding="12,10">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="field-label" VerticalAlignment="Center" Text="Tool Rail" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsSelectToolActive}"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Select"
                                Content="Select" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsBladeToolActive}"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Blade"
                                Content="Razor" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsSlipToolActive}"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Slip"
                                Content="Slip" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsRollToolActive}"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Roll"
                                Content="Roll" />
                        <Button Classes="transport functional"
                                Content="Razor at Playhead"
                                Command="{Binding SplitAtPlayheadCommand}" />
                        <Border Classes="panel-muted" Padding="8,4">
                            <TextBlock FontWeight="SemiBold" Text="Timeline Controls" />
                        </Border>
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsSnapEnabled}"
                                Command="{Binding ToggleSnapCommand}"
                                Content="Magnet" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsLinkedSelectionEnabled}"
                                Command="{Binding ToggleLinkedSelectionCommand}"
                                Content="Linked" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsV1LaneTargetActive}"
                                Command="{Binding SelectLaneTargetCommand}"
                                CommandParameter="V1"
                                Content="V1 Target" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsV2LaneTargetActive}"
                                Command="{Binding SelectLaneTargetCommand}"
                                CommandParameter="V2"
                                Content="V2 Target" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsA1LaneTargetActive}"
                                Command="{Binding SelectLaneTargetCommand}"
                                CommandParameter="A1"
                                Content="A1 Target" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsA2LaneTargetActive}"
                                Command="{Binding SelectLaneTargetCommand}"
                                CommandParameter="A2"
                                Content="A2 Target" />
                        <Border Classes="panel-muted" Padding="8,4">
                            <TextBlock FontWeight="SemiBold" Text="Timeline Mini Toolbar" />
                        </Border>
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsSelectToolActive}"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Select"
                                Content="Selection" />
                        <TextBlock VerticalAlignment="Center" Text="Link" />
                        <TextBlock VerticalAlignment="Center" Text="Zoom -" />
                        <TextBlock VerticalAlignment="Center" Text="Zoom +" />
                        <Border Classes="panel-muted" Padding="8,4">
                            <TextBlock Text="{Binding TimelineZoomSummary}" />
                        </Border>
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsZoom1sActive}"
                                Command="{Binding SelectZoomPresetCommand}"
                                CommandParameter="1s"
                                Content="1s" />
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsZoom5sActive}"
                                Command="{Binding SelectZoomPresetCommand}"
                                CommandParameter="5s"
                                Content="5s" />
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsZoom10sActive}"
                                Command="{Binding SelectZoomPresetCommand}"
                                CommandParameter="10s"
                                Content="10s" />
                        <Button Classes="transport"
                                Classes.active-chip="{Binding IsZoomFullActive}"
                                Command="{Binding SelectZoomPresetCommand}"
                                CommandParameter="Full"
                                Content="Full" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="TracksWorkspacePanel"
                    Grid.Row="3"
                    Grid.ColumnSpan="3"
                    Classes="panel">
                <Grid RowDefinitions="Auto,Auto,Auto,*,80,Auto,Auto" RowSpacing="10">
                    <TextBlock Classes="section-title" Text="Timeline" />

                    <Border x:Name="CompactTimeRuler" Grid.Row="1" Classes="panel-muted" Padding="4,2" Height="24">
                        <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                            <Border Classes="panel"
                                    Padding="4,2"
                                    CornerRadius="6"
                                    Background="#0D131A"
                                    BorderBrush="#314055">
                                <TextBlock FontSize="9"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="Time Ruler" />
                            </Border>

                            <Grid Grid.Column="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                                <Border x:Name="TimelinePlayheadBadge"
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        Background="#F97316"
                                        BorderBrush="#FDBA74"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8,2"
                                        Margin="0,0,0,2">
                                    <TextBlock FontSize="10"
                                               FontWeight="SemiBold"
                                               Text="{Binding PreviewVirtualTimeText}" />
                                </Border>
                                <Border x:Name="SnapGuideLeft"
                                        Grid.RowSpan="2"
                                        HorizontalAlignment="Center"
                                        Width="1"
                                        Margin="-24,0,0,0"
                                        Background="#FDBA74"
                                        IsVisible="False" />
                                <Border x:Name="SnapGuideRight"
                                        Grid.RowSpan="2"
                                        HorizontalAlignment="Center"
                                        Width="1"
                                        Margin="24,0,0,0"
                                        Background="#FDBA74"
                                        IsVisible="False" />
                                <TextBlock Grid.Row="1" FontSize="10" HorizontalAlignment="Left" Text="{Binding TimelineRulerLeftLabel}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" FontSize="10" HorizontalAlignment="Center" Text="{Binding TimelineRulerCenterLabel}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" FontSize="10" HorizontalAlignment="Right" Text="{Binding TimelineRulerRightLabel}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Classes="panel-muted" Padding="10,8" IsVisible="False">
                        <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                            <Border Classes="panel"
                                    Padding="8"
                                    CornerRadius="6"
                                    Background="#0D131A"
                                    BorderBrush="#314055">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                    <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="Marker Rail" />
                                    <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Cuts" />
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Classes="transport functional" Content="Mark In" Command="{Binding SetInPointCommand}" />
                                <Button Classes="transport functional" Content="Mark Out" Command="{Binding SetOutPointCommand}" />
                                <Button Classes="transport functional" Content="Prev Cut" Command="{Binding PreviousCutCommand}" />
                                <Button Classes="transport functional" Content="Next Cut" Command="{Binding NextCutCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="V1LaneRow" Grid.Row="3" Classes="panel-muted" Padding="10">
                        <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                            <Border Classes="panel"
                                    Padding="8"
                                    CornerRadius="6"
                                    Background="#0D131A"
                                    BorderBrush="#314055">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                    <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="V1" />
                                    <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Video Lane" />
                                    <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Track" />
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                        <Button Classes="transport functional"
                                                Classes.active-chip="{Binding IsTrackLockActive}"
                                                Padding="6,3"
                                                MinWidth="0"
                                                Command="{Binding ToggleTrackLockCommand}"
                                                Content="Lock" />
                                        <Button Classes="transport functional"
                                                Classes.active-chip="{Binding IsTrackMuteActive}"
                                                Padding="6,3"
                                                MinWidth="0"
                                                Command="{Binding ToggleTrackMuteCommand}"
                                                Content="Mute" />
                                        <Button Classes="transport functional"
                                                Classes.active-chip="{Binding IsTrackSoloActive}"
                                                Padding="6,3"
                                                MinWidth="0"
                                                Command="{Binding ToggleTrackSoloCommand}"
                                                Content="Solo" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Column="1" MinHeight="120">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding TimelineBlocks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TimelineBlockItemViewModel">
                                                <Button Width="{Binding WidthPixels}"
                                                        MinWidth="160"
                                                        Height="120"
                                                        Padding="0"
                                                        PointerPressed="TimelineBlockPointerPressed"
                                                        Background="{Binding BackgroundBrush}"
                                                        Foreground="{Binding ForegroundBrush}"
                                                        BorderBrush="{Binding BorderBrush}"
                                                        BorderThickness="{Binding BorderThickness}">
                                                    <Grid RowDefinitions="Auto,*">
                                                        <Border x:Name="SelectedClipTitleBar"
                                                                Background="{Binding TitleBarBackgroundBrush}"
                                                                BorderBrush="{Binding TitleBarBorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                CornerRadius="6,6,0,0"
                                                                Padding="8,5">
                                                            <TextBlock FontSize="10"
                                                                       FontWeight="Bold"
                                                                       Text="{Binding SelectedTitleText}" />
                                                        </Border>
                                                        <Grid Grid.Row="1" ColumnDefinitions="10,*,10">
                                                            <Border x:Name="ClipHandleGripLeft"
                                                                    Width="6"
                                                                    Margin="2,8,0,8"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Stretch"
                                                                    Background="#9FB6CC"
                                                                    CornerRadius="3" />
                                                            <StackPanel Grid.Column="1" Margin="8" Spacing="4">
                                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                                    <Border Background="{Binding AccentBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                                                        <TextBlock FontSize="10" FontWeight="Bold" Text="{Binding SelectionBadgeText}" />
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1"
                                                                               FontWeight="Bold"
                                                                               VerticalAlignment="Center"
                                                                               Text="{Binding Label}" />
                                                                    <Border Grid.Column="2"
                                                                            Background="#132334"
                                                                            BorderBrush="#6A88A6"
                                                                            BorderThickness="1"
                                                                            CornerRadius="4"
                                                                            Padding="5,2">
                                                                        <TextBlock FontSize="10" FontWeight="Bold" Text="SRC" />
                                                                    </Border>
                                                                </Grid>
                                                                <TextBlock FontSize="11" TextWrapping="Wrap" Text="{Binding Summary}" />
                                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                                    <TextBlock FontSize="10" FontWeight="Bold" Text="DUR" />
                                                                    <TextBlock Grid.Column="1" FontSize="10" Text="{Binding Summary}" TextTrimming="CharacterEllipsis" />
                                                                </Grid>
                                                                <StackPanel x:Name="ClipThumbnailStrip" Spacing="4" IsVisible="False">
                                                                    <TextBlock FontSize="9"
                                                                               FontWeight="Bold"
                                                                               Foreground="#D7E3F1"
                                                                               Text="THUMBNAILS" />
                                                                </StackPanel>
                                                                <Grid x:Name="ClipFilmstripTicks" ColumnDefinitions="Auto,*,Auto,*,Auto" ColumnSpacing="4">
                                                                    <TextBlock FontSize="9" Foreground="#D7E3F1" Text="00:00" />
                                                                    <Border Grid.Column="1" Height="1" Background="#7FA7D8" VerticalAlignment="Center" />
                                                                    <TextBlock Grid.Column="2" FontSize="9" Foreground="#D7E3F1" Text="00:05" />
                                                                    <Border Grid.Column="3" Height="1" Background="#7FA7D8" VerticalAlignment="Center" />
                                                                    <TextBlock Grid.Column="4" FontSize="9" Foreground="#D7E3F1" Text="00:10" />
                                                                </Grid>
                                                            </StackPanel>
                                                            <Border x:Name="ClipHandleGripRight"
                                                                    Grid.Column="2"
                                                                    Width="6"
                                                                    Margin="0,8,2,8"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Stretch"
                                                                    Background="#9FB6CC"
                                                                    CornerRadius="3" />
                                                        </Grid>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border x:Name="TimelinePlayheadIndicator"
                                        Width="2"
                                        Background="#F97316"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch"
                                        IsHitTestVisible="False" />
                                <Border x:Name="TimelineMasterPlayheadGuide"
                                        Width="0"
                                        Background="#F97316"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch"
                                        IsVisible="False"
                                        IsHitTestVisible="False" />
                                <Border x:Name="TrackLaneSeparator"
                                        Height="1"
                                        Background="#2C3745"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,0,-6"
                                        IsHitTestVisible="False" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="A1LaneRow" Grid.Row="4" Classes="panel-muted" Padding="10">
                        <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                            <Border Classes="panel"
                                    Padding="8"
                                    CornerRadius="6"
                                    Background="#0D131A"
                                    BorderBrush="#314055">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                    <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="A1" />
                                    <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Audio Lane" />
                                    <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Waveform" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Background="#204931"
                                    BorderBrush="#3A8A5D"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MinHeight="60">
                                <Grid>
                                    <TextBlock Margin="16,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="#EAFBF1"
                                               Text="{Binding Item.SourceFile}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="5" Spacing="8" IsVisible="False">
                        <Border Classes="panel-muted">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Classes="field-label" Text="Hotkeys" />
                                <TextBlock Classes="section-meta" Text="V Select" />
                                <TextBlock Classes="section-meta" Text="B Razor" />
                                <TextBlock Classes="section-meta" Text="I Mark In" />
                                <TextBlock Classes="section-meta" Text="O Mark Out" />
                                <TextBlock Classes="section-meta" Text="Home Start" />
                                <TextBlock Classes="section-meta" Text="End Finish" />
                                <TextBlock Classes="section-meta" Text="J Back 25" />
                                <TextBlock Classes="section-meta" Text="K Pause" />
                                <TextBlock Classes="section-meta" Text="L Fwd 25" />
                                <TextBlock Classes="section-meta" Text="Space Play/Pause" />
                                <TextBlock Classes="section-meta" Text="Ctrl+Z Undo" />
                                <TextBlock Classes="section-meta" Text="Ctrl+Y Redo" />
                            </StackPanel>
                        </Border>
                        <Border Classes="panel-muted">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Edit Tools" />
                                <TextBlock FontWeight="SemiBold" Text="V1 Quick Edit" />
                                <TextBlock Text="Razor" />
                                <Button Classes="transport functional" Content="Delete Clip" Command="{Binding DeleteSegmentCommand}" />
                                <Button Classes="transport functional" Content="Ripple" Command="{Binding RippleDeleteCommand}" />
                                <Button Classes="transport functional" Content="&lt;-" Command="{Binding MoveLeftCommand}" />
                                <Button Classes="transport functional" Content="-&gt;" Command="{Binding MoveRightCommand}" />
                            </StackPanel>
                        </Border>
                        <Border Classes="panel-muted">
                            <WrapPanel Orientation="Horizontal" ItemHeight="30" ItemWidth="128">
                                <Button Classes="transport functional" Content="Toggle Keep/Cut" Command="{Binding ToggleKeepCutCommand}" />
                                <Button Classes="transport functional" Content="Trim Selected" Command="{Binding TrimSelectedToInOutCommand}" />
                                <Button Classes="transport functional" Content="Duplicate Selected" Command="{Binding DuplicateSelectedCommand}" />
                                <Button Classes="transport functional" Content="Merge With Next" Command="{Binding MergeWithNextCommand}" />
                                <Button Classes="transport functional" Content="Roll &lt;" Command="{Binding RollLeftCommand}" />
                                <Button Classes="transport functional" Content="Roll &gt;" Command="{Binding RollRightCommand}" />
                                <Button Classes="transport functional" Content="Insert 1s Gap" Command="{Binding InsertGapAtPlayheadCommand}" />
                                <Button Classes="transport functional" Content="Undo" Command="{Binding UndoCommand}" />
                                <Button Classes="transport functional" Content="Redo" Command="{Binding RedoCommand}" />
                                <Button Classes="transport functional" Content="Slip &lt;" Command="{Binding SlipLeftCommand}" />
                                <Button Classes="transport functional" Content="Slip &gt;" Command="{Binding SlipRightCommand}" />
                                <Button Classes="transport functional" Content="Extract Selected" Command="{Binding ExtractSelectedToInOutCommand}" />
                            </WrapPanel>
                        </Border>
                        <Border Classes="panel-muted">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Classes="section-meta" Text="{Binding EditorHint}" />
                            </StackPanel>
                        </Border>
                        <Border Classes="panel-muted">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Reset" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="V2LaneRow" Classes="panel-muted">
                            <StackPanel>
                                <TextBlock Text="V2" />
                                <TextBlock Text="Overlay Lane" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="A2LaneRow" Classes="panel-muted">
                            <StackPanel>
                                <TextBlock Text="A2" />
                                <TextBlock Text="Audio Lane 2" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="TimelineNavigatorRow" Classes="panel-muted">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Timeline Navigator" />
                                <Border x:Name="TimelineNavigatorThumb"
                                        Width="48"
                                        Height="12"
                                        Background="#4B5E7A" />
                                <TextBlock Text="Full Timeline" />
                            </StackPanel>
                        </Border>
                        <Border Classes="panel-muted">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Timeline Options" />
                                <Button Classes="transport" Content="Track Height" />
                                <Button Classes="transport" Content="Clip Color" />
                                <Button Classes="transport" Content="Retime" />
                                <TextBlock Classes="section-meta"
                                           VerticalAlignment="Center"
                                           Text="Selection Follows Playhead" />
                            </StackPanel>
                        </Border>
                        <Border Classes="panel-muted">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Patch Panel" />
                                <Button Classes="transport" Content="Src V1" />
                                <Button Classes="transport" Content="Src A1" />
                                <Button Classes="transport" Content="Dst V1" />
                                <Button Classes="transport" Content="Dst A1" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border x:Name="TimelineBottomDockRow" Grid.Row="6" Classes="panel-muted" Padding="10,8" IsVisible="False">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Classes="field-label" VerticalAlignment="Center" Text="Page Switcher" />
                                <Button Classes="transport" Content="Media" />
                                <Button Classes="transport functional"
                                        Classes.active-chip="{Binding IsCutModeActive}"
                                        Content="Cut"
                                        Command="{Binding SelectModeCommand}"
                                        CommandParameter="Cut" />
                                <Button Classes="transport functional"
                                        Classes.active-chip="{Binding IsEditModeActive}"
                                        Content="Edit"
                                        Command="{Binding SelectModeCommand}"
                                        CommandParameter="Edit" />
                                <Button Classes="transport functional"
                                        Classes.active-chip="{Binding IsColorModeActive}"
                                        Content="Color"
                                        Command="{Binding SelectModeCommand}"
                                        CommandParameter="Color" />
                                <Button x:Name="FooterDeliverButton"
                                        Classes="transport functional"
                                        Classes.active-chip="{Binding IsDeliverModeActive}"
                                        Content="Deliver"
                                        Command="{Binding SaveToQueueCommand}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Spacing="18">
                                <TextBlock Text="Duration" />
                                <TextBlock Text="Lane Target" />
                                <TextBlock Text="Selection" />
                                <TextBlock Text="Playhead" />
                                <TextBlock Text="Mode" />
                                <TextBlock Text="{Binding ActiveLaneTarget}" />
                                <TextBlock Text="{Binding PreviewVirtualTimeText}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <TextBlock Classes="field-label" VerticalAlignment="Center" Text="Utility Status" />
                                <Button Classes="transport" Content="Render Cache" />
                                <Button Classes="transport" Content="Proxy" />
                                <Button Classes="transport" Content="Snapping" />
                                <Button Classes="transport" Content="Linked Select" />
                                <Button Classes="transport" Content="Timeline" Command="{Binding SelectBottomDockCommand}" CommandParameter="Timeline" />
                                <Button Classes="transport" Content="Mixer" Command="{Binding SelectBottomDockCommand}" CommandParameter="Mixer" />
                                <Button Classes="transport" Content="Metadata" Command="{Binding SelectBottomDockCommand}" CommandParameter="Metadata" />
                                <Button Classes="transport" Content="Markers" Command="{Binding SelectBottomDockCommand}" CommandParameter="Markers" />
                                <Button Classes="transport" Content="Scopes" Command="{Binding SelectBottomDockCommand}" CommandParameter="Scopes" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
