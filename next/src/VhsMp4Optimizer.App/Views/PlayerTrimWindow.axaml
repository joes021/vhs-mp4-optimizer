<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VhsMp4Optimizer.App.ViewModels"
        xmlns:core="using:VhsMp4Optimizer.Core.Models"
        xmlns:controls="using:VhsMp4Optimizer.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="RootWindow"
        x:Class="VhsMp4Optimizer.App.Views.PlayerTrimWindow"
        x:DataType="vm:PlayerTrimWindowViewModel"
        Width="1560"
        Height="1020"
        MinWidth="1200"
        MinHeight="820"
        WindowStartupLocation="CenterOwner"
        Title="{Binding WindowTitle}"
        Background="#14181F"
        Foreground="#E6EDF7">

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#1B222C" />
            <Setter Property="BorderBrush" Value="#2C3745" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style Selector="Border.panel-muted">
            <Setter Property="Background" Value="#111821" />
            <Setter Property="BorderBrush" Value="#2A3340" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F2F5F9" />
        </Style>

        <Style Selector="TextBlock.section-meta">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#96A4B8" />
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8FA2BA" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style Selector="Button.transport">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Background" Value="#283240" />
            <Setter Property="Foreground" Value="#EEF4FB" />
            <Setter Property="BorderBrush" Value="#314055" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.transport:pointerover">
            <Setter Property="Background" Value="#364556" />
            <Setter Property="BorderBrush" Value="#7C96B2" />
            <Setter Property="Foreground" Value="#F7FAFF" />
        </Style>

        <Style Selector="Button.transport:pressed">
            <Setter Property="Background" Value="#425366" />
            <Setter Property="BorderBrush" Value="#A1B7CF" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport:disabled">
            <Setter Property="Background" Value="#202B37" />
            <Setter Property="BorderBrush" Value="#3B4D61" />
            <Setter Property="Foreground" Value="#8EA3BA" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.transport.active-chip">
            <Setter Property="Background" Value="#506378" />
            <Setter Property="BorderBrush" Value="#A6BCD3" />
            <Setter Property="Foreground" Value="#F5FAFF" />
        </Style>

        <Style Selector="Button.transport.functional">
            <Setter Property="Background" Value="#1F8B4C" />
            <Setter Property="BorderBrush" Value="#58E293" />
            <Setter Property="Foreground" Value="#F5FFF7" />
        </Style>

        <Style Selector="Button.transport.functional:pointerover">
            <Setter Property="Background" Value="#239552" />
            <Setter Property="BorderBrush" Value="#7CF4A9" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport.functional:pressed">
            <Setter Property="Background" Value="#1C7642" />
            <Setter Property="BorderBrush" Value="#A4F6C4" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport.functional.active-chip">
            <Setter Property="Background" Value="#249855" />
            <Setter Property="BorderBrush" Value="#B3F5CC" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.transport.functional:disabled">
            <Setter Property="Background" Value="#143322" />
            <Setter Property="BorderBrush" Value="#2E6E48" />
            <Setter Property="Foreground" Value="#90C7A6" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0E7490" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBox, ComboBox, NumericUpDown">
            <Setter Property="Background" Value="#0E151D" />
            <Setter Property="Foreground" Value="#EEF4FB" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,360,Auto" Margin="14">
        <StackPanel Spacing="10" Margin="0,0,0,12">
            <Border Classes="panel-muted" Padding="10,8">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <TextBlock Classes="field-label"
                               VerticalAlignment="Center"
                               Text="DaVinci-like Menu" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="6">
                        <Button Classes="transport" Content="File" />
                        <Button Classes="transport" Content="Edit" />
                        <Button Classes="transport" Content="Trim" />
                        <Button Classes="transport" Content="Timeline" />
                        <Button Classes="transport" Content="Clip" />
                        <Button Classes="transport" Content="Mark" />
                        <Button Classes="transport" Content="View" />
                        <Button Classes="transport" Content="Playback" />
                        <Button Classes="transport" Content="Workspace" />
                        <Button Classes="transport" Content="Help" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="panel-muted" Padding="12,10">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Player / Trim" />
                        <TextBlock Classes="field-label" Text="Session Status" />
                        <TextBlock Classes="section-meta" Text="Non-linear editor mode" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="panel-muted" Padding="10,6">
                                <TextBlock FontWeight="SemiBold" Text="Project" />
                            </Border>
                            <Border Classes="panel-muted" Padding="10,6">
                                <TextBlock FontWeight="SemiBold" Text="Sequence 01" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="8"
                                HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center">
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsCutModeActive}"
                                    Content="Cut"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="Cut" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsEditModeActive}"
                                    Content="Edit"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="Edit" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsColorModeActive}"
                                    Content="Color"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="Color" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsDeliverModeActive}"
                                    Content="Deliver"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="Deliver" />
                        </StackPanel>

                        <Border Classes="panel-muted"
                                Padding="12,8"
                                HorizontalAlignment="Stretch">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold" Text="Timeline 01" />
                                    <TextBlock Classes="section-meta" Text="|" />
                                    <TextBlock Text="Record Monitor" />
                                </StackPanel>
                                <TextBlock Text="{Binding FileSummary}"
                                           TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                              ColumnSpacing="12">
                            <TextBlock Classes="field-label"
                                       VerticalAlignment="Center"
                                       Text="Timeline View" />
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Classes="transport active-chip" Content="Single Viewer" />
                                <Button Classes="transport" Content="Dual Viewer" />
                                <Button Classes="transport" Content="Inspector Right" />
                                <Button Classes="transport" Content="Mixer Right" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Classes="section-meta"
                                       Text="Workspace chrome / dock status" />
                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Right">
                                <Border Classes="panel-muted" Padding="10,6">
                                    <TextBlock FontWeight="SemiBold" Text="25 fps" />
                                </Border>
                                <Button Classes="transport functional"
                                        Classes.active-chip="{Binding IsSnapEnabled}"
                                        Content="{Binding SnapStatusText}"
                                        Command="{Binding ToggleSnapCommand}" />
                                <Border Classes="panel-muted" Padding="10,6">
                                    <TextBlock FontWeight="SemiBold" Text="Linked Selection" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center">
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsMediaPoolActive}"
                                    Content="Media Pool"
                                    Command="{Binding SelectWorkspaceDockCommand}"
                                    CommandParameter="Media Pool" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsEffectsLibraryActive}"
                                    Content="Effects Library"
                                    Command="{Binding SelectWorkspaceDockCommand}"
                                    CommandParameter="Effects Library" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsEditIndexActive}"
                                    Content="Edit Index"
                                    Command="{Binding SelectWorkspaceDockCommand}"
                                    CommandParameter="Edit Index" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsMixerActive}"
                                    Content="Mixer"
                                    Command="{Binding SelectWorkspaceDockCommand}"
                                    CommandParameter="Mixer" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Right">
                            <Button Classes="transport active-chip" Content="Edited" />
                            <Button Classes="transport" Content="Auto Save" />
                        </StackPanel>
                        <Button Classes="transport functional"
                                HorizontalAlignment="Right"
                                Content="Back to Queue"
                                Click="ClosePlayerTrimClick" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Grid x:Name="EditorMainContentGrid" Grid.Row="1" ColumnDefinitions="220,*,320" ColumnSpacing="14">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock Classes="section-title" Text="Media Pool" />
                            <TextBlock Classes="section-meta" Text="Bins i source klipovi" />
                        </StackPanel>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <TextBlock Classes="field-label"
                                       VerticalAlignment="Center"
                                       Text="Browser" />
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Classes="transport active-chip" Content="Clips" />
                                <Button Classes="transport" Content="Timelines" />
                                <Button Classes="transport" Content="Smart Bins" />
                                <Button Classes="transport" Content="Filter" />
                                <Button Classes="transport" Content="Scene" />
                                <Button Classes="transport" Content="Reel" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="92,*" ColumnSpacing="10">
                            <Border Classes="panel-muted"
                                    Padding="10"
                                    CornerRadius="8"
                                    Background="#121A24">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="field-label" Text="Bins" />
                                    <Border Background="#1A2430"
                                            BorderBrush="#324153"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,6">
                                        <TextBlock FontWeight="SemiBold" Text="Master" />
                                    </Border>
                                    <Border Background="#101822"
                                            BorderBrush="#2A394D"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,6">
                                        <TextBlock Text="Smart Bins" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Classes="field-label" Text="Clips" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="transport" Content="Sort" />
                                    <Button Classes="transport" Content="View" />
                                    <Button Classes="transport" Content="Metadata" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Classes="panel-muted"
                                            Width="104"
                                            Padding="8"
                                            Background="#181F29"
                                            BorderBrush="#395170">
                                        <StackPanel Spacing="6">
                                            <Border Height="46"
                                                    CornerRadius="6"
                                                    Background="#2B394A"
                                                    BorderBrush="#4F6B87"
                                                    BorderThickness="1" />
                                            <TextBlock FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Item.SourceFile}" />
                                            <TextBlock Classes="section-meta" Text="Source Clip" />
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="panel-muted"
                                            Width="104"
                                            Padding="8"
                                            Background="#181F29"
                                            BorderBrush="#395170">
                                        <StackPanel Spacing="6">
                                            <Border Height="46"
                                                    CornerRadius="6"
                                                    Background="#253142"
                                                    BorderBrush="#4F6B87"
                                                    BorderThickness="1" />
                                            <TextBlock FontWeight="SemiBold" Text="Timeline 01" />
                                            <TextBlock Classes="section-meta" Text="Sequence" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Border Classes="panel-muted"
                                        Padding="8,6"
                                        Background="#141C26"
                                        BorderBrush="#395170">
                                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="8">
                                        <TextBlock Classes="field-label" Text="Clip Info" />
                                        <TextBlock Grid.Column="1" Text="Date Shot" />
                                        <TextBlock Grid.Column="2" Classes="field-label" Text="Reel Name" />
                                        <TextBlock Grid.Column="3" Text="Master" />
                                        <TextBlock Grid.Column="4" Classes="field-label" Text="Camera" />
                                        <TextBlock Grid.Column="5" Text="DV Cam" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-title"
                                   FontSize="12"
                                   Text="Tool Rail" />

                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsSelectToolActive}"
                                Padding="8"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Select">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" Text="Select" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Pointer" />
                            </StackPanel>
                        </Button>

                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsBladeToolActive}"
                                Padding="8"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Blade">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" Text="Blade" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Razor" />
                            </StackPanel>
                        </Button>

                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsSlipToolActive}"
                                Padding="8"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Slip">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" Text="Slip" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Shift" />
                            </StackPanel>
                        </Button>

                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsRollToolActive}"
                                Padding="8"
                                Command="{Binding SelectToolCommand}"
                                CommandParameter="Roll">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" Text="Roll" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Edge" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Column="1" Classes="panel">
                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsSourceMonitorActive}"
                                    Content="Source"
                                    Command="{Binding SelectMonitorTabCommand}"
                                    CommandParameter="Source" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsProgramMonitorActive}"
                                    Content="Program"
                                    Command="{Binding SelectMonitorTabCommand}"
                                    CommandParameter="Program" />
                            <Border Classes="panel-muted" Padding="10,6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Fit" />
                                    <TextBlock Text="100%" />
                                    <TextBlock Text="Safe" />
                                    <TextBlock Text="Proxy Off" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="2"
                                    HorizontalAlignment="Center">
                            <TextBlock Classes="section-title"
                                       HorizontalAlignment="Center"
                                       Text="Program Monitor" />
                            <TextBlock Classes="section-meta"
                                       HorizontalAlignment="Center"
                                       Text="Playback i precizan trim kadar" />
                        </StackPanel>
                        <Border Grid.Column="2" Classes="panel-muted" Padding="10,6">
                            <TextBlock Text="{Binding PreviewSourceTimeText}" FontWeight="SemiBold" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Classes="panel-muted" Padding="10,6">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="10">
                            <TextBlock FontWeight="SemiBold" Text="Monitor Timecode" />
                            <TextBlock Grid.Column="1" Text="Source TC" />
                            <TextBlock Grid.Column="2"
                                       HorizontalAlignment="Center"
                                       Text="Record TC" />
                            <TextBlock Grid.Column="3" Text="Safe Area On" />
                            <TextBlock Grid.Column="4" Text="Proxy: Off" />
                        </Grid>
                    </Border>

                    <Border x:Name="PrimaryProgramMonitor"
                            Grid.Row="2"
                            MinHeight="400"
                            Background="#05080D"
                            BorderBrush="#293445"
                            BorderThickness="1"
                            CornerRadius="10"
                            ClipToBounds="True">
                        <Grid>
                            <Border x:Name="ProgramMonitorViewport"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="1120"
                                    MaxHeight="360"
                                    Width="1120"
                                    Height="360"
                                    Background="#05080D"
                                    BorderBrush="#293445"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    ClipToBounds="True">
                                <Grid>
                                    <controls:EmbeddedVideoView x:Name="PlaybackVideoView"
                                                                MediaPlayer="{Binding PlaybackMediaPlayerBinding}"
                                                                IsVisible="{Binding IsVideoPlaybackVisible}"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch" />
                                    <Image Source="{Binding PreviewBitmap}"
                                           IsVisible="{Binding IsPreviewImageVisible}"
                                           IsHitTestVisible="False"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Stretch="Uniform" />
                                    <Border HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="12"
                                            Background="#8C0B1220"
                                            BorderBrush="#395170"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,5">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock FontWeight="SemiBold" Text="Monitor HUD" />
                                            <TextBlock Classes="section-meta" Text="Program" />
                                        </StackPanel>
                                    </Border>
                                    <Border HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="12"
                                            Background="#8C0B1220"
                                            BorderBrush="#395170"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,5">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock FontWeight="SemiBold" Text="TC" />
                                            <TextBlock Text="{Binding PreviewSourceTimeText}" />
                                        </StackPanel>
                                    </Border>
                                    <Border HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            Margin="12"
                                            Background="#8C0B1220"
                                            BorderBrush="#395170"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,5">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock FontWeight="SemiBold" Text="SRC IN" />
                                            <TextBlock Text="{Binding InPointText}" />
                                        </StackPanel>
                                    </Border>
                                    <Border HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="12"
                                            Background="#8C0B1220"
                                            BorderBrush="#395170"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,5">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock FontWeight="SemiBold" Text="SRC OUT" />
                                            <TextBlock Text="{Binding OutPointText}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10">
                        <TextBlock VerticalAlignment="Center" Classes="field-label" Text="Virtual" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding PreviewVirtualTimeText}" />
                        <Slider Grid.Column="2"
                                Minimum="0"
                                Maximum="{Binding PreviewVirtualMaximum}"
                                Value="{Binding PreviewVirtualSeconds, Mode=TwoWay}"
                                PointerPressed="PreviewSliderPointerPressed"
                                PointerReleased="PreviewSliderPointerReleased" />
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding PreviewSourceTimeText}" />
                    </Grid>

                    <Border Grid.Row="4" Classes="panel-muted" Margin="0,8,0,0">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Classes="field-label" VerticalAlignment="Center" Text="Monitor Transport" />
                                <Button Classes="transport" Content="Shuttle -" />
                                <Button Classes="transport functional" Content="Stop" Command="{Binding PauseCommand}" />
                                <Button Classes="transport functional" Content="Loop"
                                        Classes.active-chip="{Binding IsLoopPlaybackEnabled}"
                                        Command="{Binding ToggleLoopPlaybackCommand}" />
                                <Button Classes="transport" Content="Shuttle +" />
                            </StackPanel>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal" Spacing="14">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="field-label" Text="Navigate" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Classes="transport functional" Content="START" Command="{Binding GoToStartCommand}" />
                                            <Button Classes="transport functional" Content="&lt;&lt;&lt;" Command="{Binding Back250FramesCommand}" />
                                            <Button Classes="transport functional" Content="&lt;&lt;" Command="{Binding Back25FramesCommand}" />
                                            <Button Classes="transport functional" Content="&lt;" Command="{Binding BackFrameCommand}" />
                                            <Button Classes="transport functional" Content="&gt;" Command="{Binding ForwardFrameCommand}" />
                                            <Button Classes="transport functional" Content="&gt;&gt;" Command="{Binding Forward25FramesCommand}" />
                                            <Button Classes="transport functional" Content="&gt;&gt;&gt;" Command="{Binding Forward250FramesCommand}" />
                                            <Button Classes="transport functional" Content="END" Command="{Binding GoToEndCommand}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="field-label" Text="Playback" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Classes="transport functional" Content="Play" Command="{Binding PlayCommand}" />
                                            <Button Classes="transport functional" Content="Pause" Command="{Binding PauseCommand}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="field-label" Text="Marks" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Classes="transport functional" Content="In" Command="{Binding SetInPointCommand}" />
                                            <Button Classes="transport functional" Content="Out" Command="{Binding SetOutPointCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="10">
                                <TextBlock VerticalAlignment="Center" Text="IN Point" />
                                <TextBox Grid.Column="1" Text="{Binding InPointText}" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="OUT Point" />
                                <TextBox Grid.Column="3" Text="{Binding OutPointText}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2" Spacing="12">
                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-title" Text="Inspector" />
                        <TextBlock Classes="section-meta" Text="Odabrani segment, crop i timeline komande" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <TextBlock Classes="field-label"
                                       VerticalAlignment="Center"
                                       Text="Inspector Stack" />
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Classes="transport" Content="Bypass" />
                                <Button Classes="transport" Content="Reset All" />
                                <Button Classes="transport" Content="Copy" />
                                <Button Classes="transport" Content="Paste" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <TextBlock Classes="field-label"
                                       VerticalAlignment="Center"
                                       Text="Section Status" />
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Classes="transport" Content="Open" />
                                <Button Classes="transport" Content="Keyframed" />
                                <Button Classes="transport" Content="Bypassed" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsVideoInspectorActive}"
                                    Content="Video"
                                    Command="{Binding SelectInspectorTabCommand}"
                                    CommandParameter="Video" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsAudioInspectorActive}"
                                    Content="Audio"
                                    Command="{Binding SelectInspectorTabCommand}"
                                    CommandParameter="Audio" />
                            <Button Classes="transport functional"
                                    Classes.active-chip="{Binding IsEffectsInspectorActive}"
                                    Content="Effects"
                                    Command="{Binding SelectInspectorTabCommand}"
                                    CommandParameter="Effects" />
                        </StackPanel>

                        <Border Classes="panel-muted">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="field-label" Text="Timeline Info" />
                                <TextBlock Text="{Binding TimelineSummary}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding FileSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Classes="transport functional" Content="Save to Queue" Command="{Binding SaveToQueueCommand}" />
                            <Button Grid.Column="1" Classes="transport functional" Content="Close All Gaps" Command="{Binding CloseAllGapsCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-title" Text="Transform" />

                        <Border Classes="panel-muted">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Classes="panel-muted" Padding="8,4">
                                        <TextBlock FontWeight="SemiBold" Text="Transform Reset" />
                                    </Border>
                                    <Border Classes="panel-muted" Padding="8,4">
                                        <TextBlock FontWeight="SemiBold" Text="Keyframe" />
                                    </Border>
                                </StackPanel>
                                <Grid ColumnDefinitions="Auto,70,Auto,70" ColumnSpacing="8">
                                    <TextBlock VerticalAlignment="Center" Text="Zoom X" />
                                    <TextBox Grid.Column="1" Text="1.000" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Zoom Y" />
                                    <TextBox Grid.Column="3" Text="1.000" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,70,Auto,70" ColumnSpacing="8">
                                    <TextBlock VerticalAlignment="Center" Text="Position X" />
                                    <TextBox Grid.Column="1" Text="0.000" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Position Y" />
                                    <TextBox Grid.Column="3" Text="0.000" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Classes="field-label" Text="Cropping" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="panel-muted" Padding="8,4">
                                <TextBlock Text="Reset" />
                            </Border>
                            <Border Classes="panel-muted" Padding="8,4">
                                <TextBlock Text="Keyframe" />
                            </Border>
                        </StackPanel>
                        <Grid ColumnDefinitions="110,*" ColumnSpacing="10">
                            <TextBlock VerticalAlignment="Center" Text="Aspect" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding AspectModes}" SelectedItem="{Binding SelectedAspectMode}" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,70,Auto,70" ColumnSpacing="8">
                            <TextBlock VerticalAlignment="Center" Text="Crop L" />
                            <NumericUpDown Grid.Column="1" Value="{Binding CropLeft}" Minimum="0" Maximum="2000" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Crop T" />
                            <NumericUpDown Grid.Column="3" Value="{Binding CropTop}" Minimum="0" Maximum="2000" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,70,Auto,70" ColumnSpacing="8">
                            <TextBlock VerticalAlignment="Center" Text="Crop R" />
                            <NumericUpDown Grid.Column="1" Value="{Binding CropRight}" Minimum="0" Maximum="2000" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Crop B" />
                            <NumericUpDown Grid.Column="3" Value="{Binding CropBottom}" Minimum="0" Maximum="2000" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Classes="transport functional" Content="Detect Crop" Command="{Binding DetectCropCommand}" />
                            <Button Grid.Column="1" Classes="transport functional" Content="Auto Crop" Command="{Binding AutoCropCommand}" />
                            <Button Grid.Column="2" Classes="transport functional" Content="Clear Crop" Command="{Binding ClearCropCommand}" />
                        </Grid>

                        <TextBlock Classes="field-label" Text="Composite" />
                        <Border Classes="panel-muted">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <TextBlock VerticalAlignment="Center" Text="Mode" />
                                <TextBox Grid.Column="1" Text="Normal" />
                            </Grid>
                        </Border>

                        <TextBlock Classes="field-label" Text="Retime &amp; Scaling" />
                        <Border Classes="panel-muted">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <TextBlock VerticalAlignment="Center" Text="Speed" />
                                <TextBox Grid.Column="1" Text="100.00%" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-title" Text="Metadata" />
                        <ListBox ItemsSource="{Binding Segments}" SelectedItem="{Binding SelectedSegment}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="core:TimelineSegment">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="8"
                                            Background="#101720"
                                            BorderBrush="#2A3644"
                                            BorderThickness="1">
                                        <Grid ColumnDefinitions="70,*,Auto" RowDefinitions="Auto,Auto">
                                            <TextBlock FontWeight="Bold" Text="{Binding Kind}" />
                                            <TextBlock Grid.Column="1" Text="{Binding TimelineStartSeconds, StringFormat='Timeline {0:0.00}s'}" />
                                            <TextBlock Grid.Column="2" Text="{Binding DurationSeconds, StringFormat='Trajanje {0:0.00}s'}" />
                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Margin="0,6,0,0"
                                                       Text="{Binding SourceStartSeconds, StringFormat='Source {0:0.00}s'}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,6,0,0"
                                                       Text="{Binding SourceEndSeconds, StringFormat='do {0:0.00}s'}"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Classes="panel" Margin="0,14,0,0">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                        <TextBlock Classes="section-title" Text="Timeline" />
                        <TextBlock Classes="section-meta" Text="Track view i edit akcije" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Border Classes="panel-muted" Padding="10,6">
                            <TextBlock Text="{Binding TimelineSummary}" />
                        </Border>
                        <Border Classes="panel-muted" Padding="10,6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Timeline Controls" />
                                <Button Classes="transport functional"
                                        Classes.active-chip="{Binding IsSnapEnabled}"
                                        Command="{Binding ToggleSnapCommand}"
                                        Content="Magnet" />
                                <Button Classes="transport functional"
                                        Classes.active-chip="{Binding IsV1LaneTargetActive}"
                                        Command="{Binding SelectLaneTargetCommand}"
                                        CommandParameter="V1"
                                        Content="V1 Target" />
                                <Button Classes="transport functional"
                                        Classes.active-chip="{Binding IsV2LaneTargetActive}"
                                        Command="{Binding SelectLaneTargetCommand}"
                                        CommandParameter="V2"
                                        Content="V2 Target" />
                                <Button Classes="transport functional"
                                        Classes.active-chip="{Binding IsA1LaneTargetActive}"
                                        Command="{Binding SelectLaneTargetCommand}"
                                        CommandParameter="A1"
                                        Content="A1 Target" />
                                <Button Classes="transport functional"
                                        Classes.active-chip="{Binding IsA2LaneTargetActive}"
                                        Command="{Binding SelectLaneTargetCommand}"
                                        CommandParameter="A2"
                                        Content="A2 Target" />
                                <Border Classes="panel-muted" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="Timeline Mini Toolbar" />
                                        <Button Classes="transport functional"
                                                Classes.active-chip="{Binding IsSelectToolActive}"
                                                Command="{Binding SelectToolCommand}"
                                                CommandParameter="Select"
                                                Content="Selection" />
                                        <Button Classes="transport functional"
                                                Classes.active-chip="{Binding IsLinkedSelectionEnabled}"
                                                Command="{Binding ToggleLinkedSelectionCommand}"
                                                Content="Linked" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Link" />
                                <TextBlock Text="Zoom -" />
                                <TextBlock Text="Zoom +" />
                                <Border Classes="panel-muted" Padding="8,4">
                                    <TextBlock Text="{Binding TimelineZoomSummary}" />
                                </Border>
                                <Button Classes="transport"
                                        Classes.active-chip="{Binding IsZoom1sActive}"
                                        Command="{Binding SelectZoomPresetCommand}"
                                        CommandParameter="1s"
                                        Content="1s" />
                                <Button Classes="transport"
                                        Classes.active-chip="{Binding IsZoom5sActive}"
                                        Command="{Binding SelectZoomPresetCommand}"
                                        CommandParameter="5s"
                                        Content="5s" />
                                <Button Classes="transport"
                                        Classes.active-chip="{Binding IsZoom10sActive}"
                                        Command="{Binding SelectZoomPresetCommand}"
                                        CommandParameter="10s"
                                        Content="10s" />
                                <Button Classes="transport"
                                        Classes.active-chip="{Binding IsZoomFullActive}"
                                        Command="{Binding SelectZoomPresetCommand}"
                                        CommandParameter="Full"
                                        Content="Full" />
                            </StackPanel>
                        </Border>
                        <Border Classes="panel-muted" Padding="10,6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Timeline Options" />
                                <Button Classes="transport" Content="Track Height" />
                                <Button Classes="transport" Content="Clip Color" />
                                <Button Classes="transport" Content="Retime" />
                                <TextBlock Classes="section-meta"
                                           VerticalAlignment="Center"
                                           Text="Selection Follows Playhead" />
                            </StackPanel>
                        </Border>
                        <Border Classes="panel-muted" Padding="10,6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Patch Panel" />
                                <Button Classes="transport" Content="Src V1" />
                                <Button Classes="transport" Content="Src A1" />
                                <Button Classes="transport" Content="Dst V1" />
                                <Button Classes="transport" Content="Dst A1" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border x:Name="CompactTimeRuler" Grid.Row="1" Classes="panel-muted" Padding="8,2">
                    <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                        <Border Classes="panel"
                                Padding="4"
                                CornerRadius="6"
                                Background="#0D131A"
                                BorderBrush="#314055">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Text="Time Ruler" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <Border x:Name="TimelinePlayheadBadge"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Background="#0E7490"
                                    BorderBrush="#22D3EE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8,3"
                                    Margin="0,0,0,4">
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="{Binding PreviewVirtualTimeText}" />
                            </Border>
                            <Border x:Name="SnapGuideLeft"
                                    Grid.RowSpan="2"
                                    HorizontalAlignment="Center"
                                    Width="1"
                                    Margin="-26,0,0,0"
                                    Background="#4DD0E1"
                                    Opacity="0.75"
                                    IsVisible="{Binding IsSnapEnabled}" />
                            <Border x:Name="SnapGuideRight"
                                    Grid.RowSpan="2"
                                    HorizontalAlignment="Center"
                                    Width="1"
                                    Margin="26,0,0,0"
                                    Background="#4DD0E1"
                                    Opacity="0.75"
                                    IsVisible="{Binding IsSnapEnabled}" />
                            <Border Grid.Row="1" Background="#0C131D" BorderBrush="#314055" BorderThickness="0,0,0,1" Padding="8,2">
                                <TextBlock FontSize="11" HorizontalAlignment="Left" Text="{Binding TimelineRulerLeftLabel}" />
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Background="#0C131D" BorderBrush="#314055" BorderThickness="0,0,0,1" Padding="8,2">
                                <TextBlock FontSize="11" HorizontalAlignment="Center" Text="{Binding TimelineRulerCenterLabel}" />
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" Background="#0C131D" BorderBrush="#314055" BorderThickness="0,0,0,1" Padding="8,2">
                                <TextBlock FontSize="11" HorizontalAlignment="Right" Text="{Binding TimelineRulerRightLabel}" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Classes="panel-muted">
                    <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                        <Border Classes="panel"
                                Padding="8"
                                CornerRadius="6"
                                Background="#0D131A"
                                BorderBrush="#314055">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="Marker Rail" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Cuts" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Classes="transport functional" Content="Mark In" Command="{Binding SetInPointCommand}" />
                            <Button Classes="transport functional" Content="Mark Out" Command="{Binding SetOutPointCommand}" />
                            <Button Classes="transport" Content="Prev Cut" />
                            <Button Classes="transport" Content="Next Cut" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Classes="panel-muted">
                    <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                        <Border Classes="panel"
                                Padding="8"
                                CornerRadius="6"
                                Background="#0D131A"
                                BorderBrush="#314055">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="V1" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Video Lane" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Track" />
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                    <Button Classes="transport functional"
                                            Classes.active-chip="{Binding IsTrackLockActive}"
                                            Padding="6,3"
                                            MinWidth="0"
                                            Command="{Binding ToggleTrackLockCommand}"
                                            Content="Lock" />
                                    <Button Classes="transport functional"
                                            Classes.active-chip="{Binding IsTrackMuteActive}"
                                            Padding="6,3"
                                            MinWidth="0"
                                            Command="{Binding ToggleTrackMuteCommand}"
                                            Content="Mute" />
                                    <Button Classes="transport functional"
                                            Classes.active-chip="{Binding IsTrackSoloActive}"
                                            Padding="6,3"
                                            MinWidth="0"
                                            Command="{Binding ToggleTrackSoloCommand}"
                                            Content="Solo" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding TimelineBlocks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TimelineBlockItemViewModel">
                                            <Button Width="{Binding WidthPixels}"
                                                    MinWidth="96"
                                                    Height="72"
                                                    Padding="0"
                                                    Command="{Binding DataContext.SelectTimelineBlockCommand, ElementName=RootWindow}"
                                                    CommandParameter="{Binding .}"
                                                    Background="{Binding BackgroundBrush}"
                                                    Foreground="{Binding ForegroundBrush}"
                                                    BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="{Binding BorderThickness}">
                                                <Grid RowDefinitions="Auto,*">
                                                    <Border x:Name="SelectedClipTitleBar"
                                                            Background="{Binding TitleBarBackgroundBrush}"
                                                            BorderBrush="{Binding TitleBarBorderBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            CornerRadius="6,6,0,0"
                                                            Padding="8,5">
                                                        <TextBlock FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Text="{Binding SelectedTitleText}" />
                                                    </Border>
                                                    <Grid Grid.Row="1" ColumnDefinitions="10,*,10">
                                                    <Border x:Name="ClipHandleGripLeft"
                                                            Width="6"
                                                            Margin="2,8,0,8"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Stretch"
                                                            Background="#9FB6CC"
                                                            CornerRadius="3" />
                                                    <StackPanel Grid.Column="1" Margin="8" Spacing="4">
                                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                            <Border Background="{Binding AccentBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                                                <TextBlock FontSize="10" FontWeight="Bold" Text="{Binding SelectionBadgeText}" />
                                                            </Border>
                                                            <TextBlock Grid.Column="1"
                                                                       FontWeight="Bold"
                                                                       VerticalAlignment="Center"
                                                                       Text="{Binding Label}" />
                                                            <Border Grid.Column="2"
                                                                    Background="#132334"
                                                                    BorderBrush="#6A88A6"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4"
                                                                    Padding="5,2">
                                                                <TextBlock FontSize="10" FontWeight="Bold" Text="SRC" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock FontSize="11" TextWrapping="Wrap" Text="{Binding Summary}" />
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <TextBlock FontSize="10" FontWeight="Bold" Text="DUR" />
                                                            <TextBlock Grid.Column="1" FontSize="10" Text="{Binding Summary}" TextTrimming="CharacterEllipsis" />
                                                        </Grid>
                                                        <StackPanel x:Name="ClipThumbnailStrip" Spacing="4" IsVisible="False">
                                                            <TextBlock FontSize="9"
                                                                       FontWeight="Bold"
                                                                       Foreground="#D7E3F1"
                                                                       Text="THUMBNAILS" />
                                                            <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="4">
                                                                <Border Background="#2B5BAE" BorderBrush="#8DB6FF" BorderThickness="1" CornerRadius="3" Height="16" />
                                                                <Border Grid.Column="1" Background="#254E96" BorderBrush="#8DB6FF" BorderThickness="1" CornerRadius="3" Height="16" />
                                                                <Border Grid.Column="2" Background="#315FBA" BorderBrush="#8DB6FF" BorderThickness="1" CornerRadius="3" Height="16" />
                                                                <Border Grid.Column="3" Background="#28539F" BorderBrush="#8DB6FF" BorderThickness="1" CornerRadius="3" Height="16" />
                                                                <Border Grid.Column="4" Background="#3465C4" BorderBrush="#8DB6FF" BorderThickness="1" CornerRadius="3" Height="16" />
                                                                <Border Grid.Column="5" Background="#29539D" BorderBrush="#8DB6FF" BorderThickness="1" CornerRadius="3" Height="16" />
                                                            </Grid>
                                                            <Grid x:Name="ClipFilmstripTicks" ColumnDefinitions="Auto,*,Auto,*,Auto" ColumnSpacing="4">
                                                                <TextBlock FontSize="9" Foreground="#D7E3F1" Text="00:00" />
                                                                <Border Grid.Column="1" Height="1" Background="#7FA7D8" VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="2" FontSize="9" Foreground="#D7E3F1" Text="00:05" />
                                                                <Border Grid.Column="3" Height="1" Background="#7FA7D8" VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="4" FontSize="9" Foreground="#D7E3F1" Text="00:10" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border x:Name="ClipHandleGripRight"
                                                            Grid.Column="2"
                                                            Width="6"
                                                            Margin="0,8,2,8"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Stretch"
                                                            Background="#9FB6CC"
                                                            CornerRadius="3" />
                                                    </Grid>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border x:Name="TimelinePlayheadIndicator"
                                    Width="2"
                                    Background="#22D3EE"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch"
                                    IsHitTestVisible="False" />
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="V2LaneRow" Grid.Row="4" Classes="panel-muted" IsVisible="False">
                    <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                        <Border Classes="panel"
                                Padding="8"
                                CornerRadius="6"
                                Background="#0D131A"
                                BorderBrush="#314055">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="V2" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Overlay Lane" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Video 2" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#101720"
                                BorderBrush="#29384B"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,12">
                            <Grid ColumnDefinitions="1.2*,0.9*,1.1*" ColumnSpacing="10">
                                <Border Background="#192431"
                                        BorderBrush="#42617F"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Height="58"
                                        Opacity="0.8" />
                                <Border Grid.Column="1"
                                        Background="#15202C"
                                        BorderBrush="#34506C"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Height="58"
                                        Opacity="0.7" />
                                <Border Grid.Column="2"
                                        Background="#182634"
                                        BorderBrush="#42617F"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Height="58"
                                        Opacity="0.75" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="TrackLaneSeparator"
                        Grid.Row="5"
                        IsVisible="False"
                        Background="#18222E"
                        BorderBrush="#304153"
                        BorderThickness="0,1,0,1"
                        CornerRadius="6"
                        Padding="10,4">
                    <TextBlock Classes="section-meta"
                               HorizontalAlignment="Center"
                               Text="Track Separator" />
                </Border>

                <Border x:Name="A1LaneRow" Grid.Row="6" Classes="panel-muted">
                    <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                        <Border Classes="panel"
                                Padding="8"
                                CornerRadius="6"
                                Background="#0D131A"
                                BorderBrush="#314055">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="A1" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Audio Lane" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Waveform" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#0F151E"
                                BorderBrush="#263444"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,14">
                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10" VerticalAlignment="Center">
                                <Border Background="#1F4C63" Height="28" CornerRadius="4" VerticalAlignment="Center" Opacity="0.85" />
                                <Border Grid.Column="1" Background="#2A607A" Height="40" CornerRadius="4" VerticalAlignment="Center" Opacity="0.85" />
                                <Border Grid.Column="2" Background="#1F4C63" Height="22" CornerRadius="4" VerticalAlignment="Center" Opacity="0.85" />
                                <Border Grid.Column="3" Background="#2A607A" Height="34" CornerRadius="4" VerticalAlignment="Center" Opacity="0.85" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="A2LaneRow" Grid.Row="7" Classes="panel-muted" IsVisible="False">
                    <Grid ColumnDefinitions="112,*" ColumnSpacing="10">
                        <Border Classes="panel"
                                Padding="8"
                                CornerRadius="6"
                                Background="#0D131A"
                                BorderBrush="#314055">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="A2" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Audio Lane 2" />
                                <TextBlock Classes="section-meta" HorizontalAlignment="Center" Text="Waveform" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#0F151E"
                                BorderBrush="#263444"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,14"
                                Opacity="0.82">
                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10" VerticalAlignment="Center">
                                <Border Background="#27485F" Height="20" CornerRadius="4" VerticalAlignment="Center" />
                                <Border Grid.Column="1" Background="#30576F" Height="30" CornerRadius="4" VerticalAlignment="Center" />
                                <Border Grid.Column="2" Background="#27485F" Height="18" CornerRadius="4" VerticalAlignment="Center" />
                                <Border Grid.Column="3" Background="#30576F" Height="24" CornerRadius="4" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="3"
                      Grid.RowSpan="5"
                      ColumnDefinitions="112,*"
                      IsHitTestVisible="False">
                    <Border x:Name="TimelineMasterPlayheadGuide"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Stretch"
                            Width="2"
                            Margin="0,8,0,8"
                            CornerRadius="1"
                            Background="#F97316"
                            Opacity="0.75" />
                </Grid>

                <StackPanel Grid.Row="8" Spacing="8">
                    <TextBlock Classes="field-label" Text="Edit Tools" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="transport functional" Content="Razor at Playhead" Command="{Binding SplitAtPlayheadCommand}" />
                        <Button Classes="transport functional" Content="Toggle Keep/Cut" Command="{Binding ToggleKeepCutCommand}" />
                        <Button Classes="transport functional" Content="Trim Selected" Command="{Binding TrimSelectedToInOutCommand}" />
                        <Button Classes="transport functional" Content="Extract Selected" Command="{Binding ExtractSelectedToInOutCommand}" />
                        <Button Classes="transport functional" Content="Duplicate Selected" Command="{Binding DuplicateSelectedCommand}" />
                        <Button Classes="transport functional" Content="Merge With Next" Command="{Binding MergeWithNextCommand}" />
                        <Button Classes="transport functional" Content="Roll &lt;" Command="{Binding RollLeftCommand}" />
                        <Button Classes="transport functional" Content="Roll &gt;" Command="{Binding RollRightCommand}" />
                        <Button Classes="transport functional" Content="Insert 1s Gap" Command="{Binding InsertGapAtPlayheadCommand}" />
                        <Button Classes="transport functional" Content="Undo" Command="{Binding UndoCommand}" />
                        <Button Classes="transport functional" Content="Redo" Command="{Binding RedoCommand}" />
                        <Button Classes="transport functional" Content="Slip &lt;" Command="{Binding SlipLeftCommand}" />
                        <Button Classes="transport functional" Content="Slip &gt;" Command="{Binding SlipRightCommand}" />
                        <Button Classes="transport functional" Content="Cut Segment" Command="{Binding CutSegmentCommand}" />
                        <Button Classes="transport functional" Content="Delete" Command="{Binding DeleteSegmentCommand}" />
                        <Button Classes="transport functional" Content="Ripple Delete" Command="{Binding RippleDeleteCommand}" />
                        <Button Classes="transport functional" Content="Move Left" Command="{Binding MoveLeftCommand}" />
                        <Button Classes="transport functional" Content="Move Right" Command="{Binding MoveRightCommand}" />
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <Border x:Name="TimelineBottomDockRow" Grid.Row="9" Classes="panel-muted" IsVisible="False">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsTimelineBottomDockActive}"
                                Command="{Binding SelectBottomDockCommand}"
                                CommandParameter="Timeline"
                                Content="Timeline" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsMixerBottomDockActive}"
                                Command="{Binding SelectBottomDockCommand}"
                                CommandParameter="Mixer"
                                Content="Mixer" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsMetadataBottomDockActive}"
                                Command="{Binding SelectBottomDockCommand}"
                                CommandParameter="Metadata"
                                Content="Metadata" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsMarkersBottomDockActive}"
                                Command="{Binding SelectBottomDockCommand}"
                                CommandParameter="Markers"
                                Content="Markers" />
                        <Button Classes="transport functional"
                                Classes.active-chip="{Binding IsScopesBottomDockActive}"
                                Command="{Binding SelectBottomDockCommand}"
                                CommandParameter="Scopes"
                                Content="Scopes" />
                    </StackPanel>
                </Border>

                <Border x:Name="TimelineNavigatorRow" Grid.Row="10" Classes="panel-muted" IsVisible="False">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                        <Border Classes="panel"
                                Padding="8,6"
                                CornerRadius="6"
                                Background="#16202B"
                                BorderBrush="#36506B">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <TextBlock FontWeight="SemiBold" VerticalAlignment="Center" Text="Timeline Navigator" />
                                <Border Grid.Column="1"
                                        Background="#0D131A"
                                        BorderBrush="#33465C"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Height="18"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <Border Background="#223246"
                                                Margin="6,3"
                                                CornerRadius="4"
                                                Opacity="0.75" />
                                        <Border x:Name="TimelineNavigatorThumb"
                                                Width="160"
                                                HorizontalAlignment="Center"
                                                Margin="0,2"
                                                Background="#4F84C4"
                                                BorderBrush="#C5DCF8"
                                                BorderThickness="1"
                                                CornerRadius="4" />
                                    </Grid>
                                </Border>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Full Timeline" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" ColumnDefinitions="2.2*,1.2*,1*" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <Border Classes="panel"
                                        Padding="8,6"
                                        CornerRadius="6"
                                        Background="#16202B"
                                        BorderBrush="#36506B">
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                        <StackPanel Spacing="2">
                                            <TextBlock Classes="field-label" Text="Record TC" />
                                            <TextBlock Text="{Binding PreviewSourceTimeText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Classes="field-label" Text="Lane Target" />
                                            <TextBlock Text="{Binding ActiveLaneTarget}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="2">
                                            <TextBlock Classes="field-label" Text="Tool" />
                                            <TextBlock Text="{Binding ActiveTool}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <TextBlock Classes="field-label" Text="Selection" />
                                <TextBlock Text="{Binding EditorHint}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                                <Border Classes="panel"
                                        Padding="8,6"
                                        CornerRadius="6"
                                        Background="#16202B"
                                        BorderBrush="#36506B">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="field-label" Text="Selected Clip" />
                                        <TextBlock Text="{Binding SelectedClipSummary}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Classes="field-label" Text="Playhead" />
                                <TextBlock Text="{Binding PreviewVirtualTimeText}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Classes="field-label" Text="Mode" />
                                <TextBlock Text="Trim / Timeline" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Classes="panel-muted"
                Padding="12,8">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <TextBlock Classes="field-label"
                           VerticalAlignment="Center"
                           Text="Page Switcher" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Classes="transport" Content="Media" />
                    <Button Classes="transport active-chip" Content="Cut" />
                    <Button Classes="transport" Content="Edit" />
                    <Button Classes="transport" Content="Color" />
                    <Button x:Name="FooterDeliverButton"
                            Classes="transport functional"
                            Content="Deliver"
                            Command="{Binding SaveToQueueCommand}"
                            Click="ClosePlayerTrimClick" />
                </StackPanel>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right">
                    <TextBlock Classes="field-label"
                               VerticalAlignment="Center"
                               Text="Utility Status" />
                    <Button Classes="transport" Content="Render Cache" />
                    <Button Classes="transport" Content="Proxy" />
                    <Button Classes="transport" Content="Snapping" />
                    <Button Classes="transport" Content="Linked Select" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
